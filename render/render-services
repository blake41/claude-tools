#!/bin/bash
set -euo pipefail

REAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$REAL_SCRIPT")"

source "$SCRIPT_DIR/render-common.sh"
source "$SCRIPT_DIR/../cli-envelope.sh"

TOOL_NAME="render-services"

cmd_list() {
    load_api_key || json_error "$TOOL_NAME list" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"
    local owner_id
    owner_id=$(load_workspace) || true

    local url="/services?limit=50"
    if [[ -n "$owner_id" ]]; then
        url="$url&ownerId=$owner_id"
    fi

    local raw
    raw=$(render_api "$url")

    local services
    services=$(echo "$raw" | jq '[.[] | .service | {id, name, type, url: (.serviceDetails.url // null)}]')

    local na
    local first_id
    first_id=$(echo "$services" | jq -r '.[0].id // empty')
    if [[ -n "$first_id" ]]; then
        na=$(next_actions \
            "$(next_action "render-services get $first_id" "Get details for first service")" \
            "$(next_action "render-logs $first_id" "View logs for first service")")
    else
        na=$(next_actions)
    fi

    json_ok "$TOOL_NAME list" "$services" "$na"
}

cmd_get() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME get" "Service ID required" "MISSING_ARG" "Usage: render-services get <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME get" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api "/services/$service_id")

    local na
    na=$(next_actions \
        "$(next_action "render-services deploys $service_id" "View recent deploys")" \
        "$(next_action "render-services env $service_id" "View environment variables")" \
        "$(next_action "render-logs $service_id" "View logs for this service")")

    json_ok "$TOOL_NAME get" "$result" "$na"
}

cmd_deploys() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME deploys" "Service ID required" "MISSING_ARG" "Usage: render-services deploys <service-id> [--limit N]"
    fi
    local limit="${2:-10}"

    load_api_key || json_error "$TOOL_NAME deploys" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local raw
    raw=$(render_api "/services/$service_id/deploys?limit=$limit")

    # Check for API error (non-array response)
    if ! echo "$raw" | jq -e 'type == "array"' >/dev/null 2>&1; then
        local msg
        msg=$(echo "$raw" | jq -r '.message // "Unknown error"' 2>/dev/null || echo "$raw")
        json_error "$TOOL_NAME deploys" "$msg" "API_ERROR" "Check the service ID: render-services list"
        return
    fi

    local deploys
    deploys=$(echo "$raw" | jq '[.[] | (.deploy // .) | {
        id, status,
        trigger: (.trigger // "unknown"),
        commit: (.commit // {}),
        createdAt, updatedAt,
        finishedAt: (.finishedAt // null)
    }]')

    local na
    na=$(next_actions \
        "$(next_action "render-services get $service_id" "View service details")" \
        "$(next_action "render-logs $service_id" "View logs")" \
        "$(next_action "render-services env $service_id" "View environment variables")")

    json_ok "$TOOL_NAME deploys" "$deploys" "$na"
}

cmd_env() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME env" "Service ID required" "MISSING_ARG" "Usage: render-services env <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME env" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local raw
    raw=$(render_api "/services/$service_id/env-vars")

    # Mask secret values (show first 4 chars + ...)
    local env_vars
    env_vars=$(echo "$raw" | jq '[.[] | .envVar | {
        key, value: (if .value then (.value[:4] + "...") else "(secret)" end)
    }]')

    local na
    na=$(next_actions \
        "$(next_action "render-services env-set $service_id KEY VALUE" "Set an environment variable")" \
        "$(next_action "render-services get $service_id" "View service details")" \
        "$(next_action "render-services deploys $service_id" "View recent deploys")")

    json_ok "$TOOL_NAME env" "$env_vars" "$na"
}

cmd_deploy() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME deploy" "Service ID required" "MISSING_ARG" "Usage: render-services deploy <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME deploy" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_post "/services/$service_id/deploys" '{}')

    local deploy
    deploy=$(echo "$result" | jq '{id: .id, status: .status, trigger: .trigger, createdAt: .createdAt}')

    local deploy_id
    deploy_id=$(echo "$result" | jq -r '.id // empty')

    local na
    na=$(next_actions \
        "$(next_action "render-services deploys $service_id" "Check deploy status")" \
        "$(next_action "render-logs $service_id --type build" "View build logs")" \
        "$(next_action "render-services deploy-cancel $service_id $deploy_id" "Cancel this deploy")")

    json_ok "$TOOL_NAME deploy" "$deploy" "$na"
}

cmd_deploy_cancel() {
    local service_id="${1:-}"
    local deploy_id="${2:-}"
    if [[ -z "$service_id" || -z "$deploy_id" ]]; then
        json_error "$TOOL_NAME deploy-cancel" "Service ID and deploy ID required" "MISSING_ARG" \
            "Usage: render-services deploy-cancel <service-id> <deploy-id>"
    fi

    load_api_key || json_error "$TOOL_NAME deploy-cancel" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_post "/services/$service_id/deploys/$deploy_id/cancel" '{}')

    local na
    na=$(next_actions \
        "$(next_action "render-services deploys $service_id" "Check deploy status")" \
        "$(next_action "render-services get $service_id" "View service details")")

    json_ok "$TOOL_NAME deploy-cancel" "$(jq -n --arg id "$deploy_id" '{id: $id, cancelled: true}')" "$na"
}

cmd_restart() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME restart" "Service ID required" "MISSING_ARG" "Usage: render-services restart <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME restart" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_post "/services/$service_id/restart" '{}')

    local na
    na=$(next_actions \
        "$(next_action "render-services get $service_id" "Check service status")" \
        "$(next_action "render-logs $service_id" "View logs")")

    json_ok "$TOOL_NAME restart" "$(jq -n --arg id "$service_id" '{id: $id, restarted: true}')" "$na"
}

cmd_suspend() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME suspend" "Service ID required" "MISSING_ARG" "Usage: render-services suspend <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME suspend" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_post "/services/$service_id/suspend" '{}')

    local na
    na=$(next_actions \
        "$(next_action "render-services resume $service_id" "Resume the service")" \
        "$(next_action "render-services get $service_id" "Check service status")")

    json_ok "$TOOL_NAME suspend" "$(jq -n --arg id "$service_id" '{id: $id, suspended: true}')" "$na"
}

cmd_resume() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME resume" "Service ID required" "MISSING_ARG" "Usage: render-services resume <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME resume" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_post "/services/$service_id/resume" '{}')

    local na
    na=$(next_actions \
        "$(next_action "render-services get $service_id" "Check service status")" \
        "$(next_action "render-logs $service_id" "View logs")")

    json_ok "$TOOL_NAME resume" "$(jq -n --arg id "$service_id" '{id: $id, resumed: true}')" "$na"
}

cmd_events() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME events" "Service ID required" "MISSING_ARG" "Usage: render-services events <service-id> [--limit N]"
    fi
    shift
    local limit=20
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --limit) limit="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    load_api_key || json_error "$TOOL_NAME events" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local raw
    raw=$(render_api "/services/$service_id/events?limit=$limit")

    local events
    events=$(echo "$raw" | jq '[.[] | .event // . | {id, type, timestamp, details}]' 2>/dev/null || echo "$raw")

    local na
    na=$(next_actions \
        "$(next_action "render-services get $service_id" "View service details")" \
        "$(next_action "render-services deploys $service_id" "View recent deploys")" \
        "$(next_action "render-logs $service_id" "View logs")")

    json_ok "$TOOL_NAME events" "$events" "$na"
}

cmd_scale() {
    local service_id="${1:-}"
    local num_instances="${2:-}"
    if [[ -z "$service_id" || -z "$num_instances" ]]; then
        json_error "$TOOL_NAME scale" "Service ID and instance count required" "MISSING_ARG" \
            "Usage: render-services scale <service-id> <num-instances>"
    fi

    load_api_key || json_error "$TOOL_NAME scale" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_post "/services/$service_id/scale" "{\"numInstances\":$num_instances}")

    local na
    na=$(next_actions \
        "$(next_action "render-services get $service_id" "Check service status")" \
        "$(next_action "render-services instances $service_id" "View running instances")")

    json_ok "$TOOL_NAME scale" "$(jq -n --arg id "$service_id" --argjson n "$num_instances" '{id: $id, numInstances: $n, scaled: true}')" "$na"
}

cmd_instances() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME instances" "Service ID required" "MISSING_ARG" "Usage: render-services instances <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME instances" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local raw
    raw=$(render_api "/services/$service_id/instances")

    local instances
    instances=$(echo "$raw" | jq '[.[] | .instance // . | {id, status, createdAt, updatedAt}]' 2>/dev/null || echo "$raw")

    local na
    na=$(next_actions \
        "$(next_action "render-services scale $service_id N" "Scale instances")" \
        "$(next_action "render-services get $service_id" "View service details")")

    json_ok "$TOOL_NAME instances" "$instances" "$na"
}

cmd_rollback() {
    local service_id="${1:-}"
    local deploy_id="${2:-}"
    if [[ -z "$service_id" || -z "$deploy_id" ]]; then
        json_error "$TOOL_NAME rollback" "Service ID and deploy ID required" "MISSING_ARG" \
            "Usage: render-services rollback <service-id> <deploy-id>"
    fi

    load_api_key || json_error "$TOOL_NAME rollback" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_post "/services/$service_id/rollback" "{\"deployId\":\"$deploy_id\"}")

    local na
    na=$(next_actions \
        "$(next_action "render-services deploys $service_id" "Check deploy status")" \
        "$(next_action "render-logs $service_id" "View logs")")

    json_ok "$TOOL_NAME rollback" "$result" "$na"
}

cmd_custom_domains() {
    local service_id="${1:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME custom-domains" "Service ID required" "MISSING_ARG" "Usage: render-services custom-domains <service-id>"
    fi

    load_api_key || json_error "$TOOL_NAME custom-domains" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local raw
    raw=$(render_api "/services/$service_id/custom-domains")

    local domains
    domains=$(echo "$raw" | jq '[.[] | .customDomain // . | {id, name, domainType, verificationStatus, createdAt}]' 2>/dev/null || echo "$raw")

    local na
    na=$(next_actions \
        "$(next_action "render-services get $service_id" "View service details")")

    json_ok "$TOOL_NAME custom-domains" "$domains" "$na"
}

cmd_pre_deploy() {
    local service_id="${1:-}"
    local command="${2:-}"
    if [[ -z "$service_id" ]]; then
        json_error "$TOOL_NAME pre-deploy" "Service ID required" "MISSING_ARG" \
            "Usage: render-services pre-deploy <service-id> [command]"
    fi

    load_api_key || json_error "$TOOL_NAME pre-deploy" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    if [[ -z "$command" ]]; then
        # GET mode: show current pre-deploy command
        local result
        result=$(render_api "/services/$service_id")
        local current
        current=$(echo "$result" | jq -r '.serviceDetails.envSpecificDetails.preDeployCommand // "(not set)"')

        local na
        na=$(next_actions \
            "$(next_action "render-services pre-deploy $service_id \"bun run migrate\"" "Set pre-deploy command")" \
            "$(next_action "render-services get $service_id" "View service details")")

        json_ok "$TOOL_NAME pre-deploy" "$(jq -n --arg cmd "$current" '{preDeployCommand: $cmd}')" "$na"
    else
        # SET mode: update pre-deploy command via PATCH
        local result
        result=$(curl -sS -X PATCH "https://api.render.com/v1/services/$service_id" \
            -H "Authorization: Bearer $RENDER_API_KEY" \
            -H "Content-Type: application/json" \
            -d "$(jq -n --arg cmd "$command" '{serviceDetails: {preDeployCommand: $cmd}}')")

        local actual
        actual=$(echo "$result" | jq -r '.serviceDetails.envSpecificDetails.preDeployCommand // "(not set)"')

        local na
        na=$(next_actions \
            "$(next_action "render-services pre-deploy $service_id" "Verify pre-deploy command")" \
            "$(next_action "render-services deploy $service_id" "Deploy to run it")")

        json_ok "$TOOL_NAME pre-deploy" "$(jq -n --arg cmd "$actual" '{preDeployCommand: $cmd, updated: true}')" "$na"
    fi
}

cmd_env_group_create() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        json_error "$TOOL_NAME env-group-create" "Name required" "MISSING_ARG" \
            "Usage: render-services env-group-create <name>"
    fi

    load_api_key || json_error "$TOOL_NAME env-group-create" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local owner_id
    owner_id=$(load_workspace) || true

    local body
    body=$(jq -n --arg name "$name" --arg oid "$owner_id" \
        'if $oid != "" then {name: $name, ownerId: $oid} else {name: $name} end')

    local result
    result=$(render_api_post "/env-groups" "$body")

    local group_id
    group_id=$(echo "$result" | jq -r '.envGroup.id // .id // empty')

    local na
    na=$(next_actions \
        "$(next_action "render-services env-group-set $group_id KEY VALUE" "Add a variable")" \
        "$(next_action "render-services env-group-env $group_id" "List variables")" \
        "$(next_action "render-services env-group-delete $group_id" "Delete this group")")

    json_ok "$TOOL_NAME env-group-create" "$result" "$na"
}

cmd_env_group_delete() {
    local group_id="${1:-}"
    if [[ -z "$group_id" ]]; then
        json_error "$TOOL_NAME env-group-delete" "Env group ID required" "MISSING_ARG" \
            "Usage: render-services env-group-delete <env-group-id>"
    fi

    load_api_key || json_error "$TOOL_NAME env-group-delete" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local result
    result=$(render_api_delete "/env-groups/$group_id")

    local na
    na=$(next_actions)

    json_ok "$TOOL_NAME env-group-delete" "$(jq -n --arg id "$group_id" '{id: $id, deleted: true}')" "$na"
}

cmd_env_group_env() {
    local group_id="${1:-}"
    if [[ -z "$group_id" ]]; then
        json_error "$TOOL_NAME env-group-env" "Env group ID required" "MISSING_ARG" \
            "Usage: render-services env-group-env <env-group-id>"
    fi

    load_api_key || json_error "$TOOL_NAME env-group-env" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    local raw
    raw=$(render_api "/env-groups/$group_id")

    local env_vars
    env_vars=$(echo "$raw" | jq '[.envVars[] | {key, value: (if .value then (.value[:4] + "...") else "(secret)" end)}]')

    local na
    na=$(next_actions \
        "$(next_action "render-services env-group-set $group_id KEY VALUE" "Set an env var on this group")")

    json_ok "$TOOL_NAME env-group-env" "$env_vars" "$na"
}

cmd_env_group_set() {
    local group_id="${1:-}"
    local key="${2:-}"
    local value="${3:-}"
    if [[ -z "$group_id" || -z "$key" || -z "$value" ]]; then
        json_error "$TOOL_NAME env-group-set" "Env group ID, key, and value required" "MISSING_ARG" \
            "Usage: render-services env-group-set <env-group-id> <KEY> <VALUE>"
    fi

    load_api_key || json_error "$TOOL_NAME env-group-set" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    # Per-key PUT: adds or updates a single var without replacing others
    local result
    result=$(render_api_put "/env-groups/$group_id/env-vars/$key" "$(jq -n --arg v "$value" '{value: $v}')")

    local na
    na=$(next_actions \
        "$(next_action "render-services env-group-env $group_id" "View all env group vars")")

    json_ok "$TOOL_NAME env-group-set" "$(jq -n --arg key "$key" '{key: $key, updated: true}')" "$na"
}

cmd_env_set() {
    local service_id="${1:-}"
    local key="${2:-}"
    local value="${3:-}"
    if [[ -z "$service_id" || -z "$key" || -z "$value" ]]; then
        json_error "$TOOL_NAME env-set" "Service ID, key, and value required" "MISSING_ARG" \
            "Usage: render-services env-set <service-id> <KEY> <VALUE>"
    fi

    load_api_key || json_error "$TOOL_NAME env-set" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

    # SAFE: GET existing vars, merge the new one, PUT the full list back.
    # Render PUT /env-vars REPLACES ALL vars — sending only the new var deletes everything else.
    local existing
    existing=$(render_api "/services/$service_id/env-vars")

    # Build merged list: existing vars (minus the key being set) + the new key
    local merged
    merged=$(echo "$existing" | jq --arg key "$key" --arg value "$value" \
        '[.[] | .envVar | {key, value}] | map(select(.key != $key)) + [{key: $key, value: $value}]')

    local result
    result=$(render_api_put "/services/$service_id/env-vars" "$merged")

    local na
    na=$(next_actions \
        "$(next_action "render-services env $service_id" "View all env vars")" \
        "$(next_action "render-services deploys $service_id" "Check deploy status")")

    json_ok "$TOOL_NAME env-set" "$(jq -n --arg key "$key" '{key: $key, updated: true}')" "$na"
}

case "${1:-}" in
    list)
        cmd_list
        ;;
    get)
        cmd_get "${2:-}"
        ;;
    deploys)
        shift; cmd_deploys "$@"
        ;;
    deploy)
        cmd_deploy "${2:-}"
        ;;
    deploy-cancel)
        shift; cmd_deploy_cancel "$@"
        ;;
    restart)
        cmd_restart "${2:-}"
        ;;
    suspend)
        cmd_suspend "${2:-}"
        ;;
    resume)
        cmd_resume "${2:-}"
        ;;
    events)
        shift; cmd_events "$@"
        ;;
    scale)
        shift; cmd_scale "$@"
        ;;
    instances)
        cmd_instances "${2:-}"
        ;;
    rollback)
        shift; cmd_rollback "$@"
        ;;
    custom-domains)
        cmd_custom_domains "${2:-}"
        ;;
    env)
        cmd_env "${2:-}"
        ;;
    env-set)
        shift; cmd_env_set "$@"
        ;;
    env-group-create)
        cmd_env_group_create "${2:-}"
        ;;
    env-group-delete)
        cmd_env_group_delete "${2:-}"
        ;;
    env-group-env)
        cmd_env_group_env "${2:-}"
        ;;
    env-group-set)
        shift; cmd_env_group_set "$@"
        ;;
    pre-deploy)
        shift; cmd_pre_deploy "$@"
        ;;
    *)
        cmd_tree "$TOOL_NAME" "Render.com service management" "$(jq -n '[
            {name: "list", description: "List all services", usage: "render-services list"},
            {name: "get", description: "Get service details", usage: "render-services get <service-id>"},
            {name: "deploy", description: "Trigger a deploy", usage: "render-services deploy <service-id>"},
            {name: "deploy-cancel", description: "Cancel a running deploy", usage: "render-services deploy-cancel <service-id> <deploy-id>"},
            {name: "deploys", description: "List recent deploys", usage: "render-services deploys <service-id> [--limit N]"},
            {name: "restart", description: "Restart a service", usage: "render-services restart <service-id>"},
            {name: "suspend", description: "Suspend a service", usage: "render-services suspend <service-id>"},
            {name: "resume", description: "Resume a suspended service", usage: "render-services resume <service-id>"},
            {name: "events", description: "View service event history", usage: "render-services events <service-id> [--limit N]"},
            {name: "scale", description: "Scale service instances", usage: "render-services scale <service-id> <num-instances>"},
            {name: "instances", description: "List running instances", usage: "render-services instances <service-id>"},
            {name: "rollback", description: "Rollback to a previous deploy", usage: "render-services rollback <service-id> <deploy-id>"},
            {name: "custom-domains", description: "List custom domains", usage: "render-services custom-domains <service-id>"},
            {name: "env", description: "List environment variables (masked)", usage: "render-services env <service-id>"},
            {name: "env-set", description: "Set an environment variable", usage: "render-services env-set <service-id> <KEY> <VALUE>"},
            {name: "env-group-create", description: "Create an env group", usage: "render-services env-group-create <name>"},
            {name: "env-group-delete", description: "Delete an env group", usage: "render-services env-group-delete <env-group-id>"},
            {name: "env-group-env", description: "List env group variables (masked)", usage: "render-services env-group-env <env-group-id>"},
            {name: "env-group-set", description: "Set an env group variable", usage: "render-services env-group-set <env-group-id> <KEY> <VALUE>"},
            {name: "pre-deploy", description: "Get or set pre-deploy command", usage: "render-services pre-deploy <service-id> [command]"}
        ]')"
        ;;
esac

#!/bin/bash
set -euo pipefail

REAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$REAL_SCRIPT")"

source "$SCRIPT_DIR/render-common.sh"
source "$SCRIPT_DIR/../cli-envelope.sh"

TOOL_NAME="render-logs"

# Defaults
LINES=50
LOG_TYPE=""
LOG_LEVEL=""
SINCE=""
START_TIME=""
END_TIME=""
DIRECTION=""

# Parse arguments
SERVICE_ID=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --lines|-n)
            LINES="$2"
            shift 2
            ;;
        --type)
            LOG_TYPE="$2"
            shift 2
            ;;
        --level)
            LOG_LEVEL="$2"
            shift 2
            ;;
        --since)
            SINCE="$2"
            shift 2
            ;;
        --start)
            START_TIME="$2"
            shift 2
            ;;
        --end)
            END_TIME="$2"
            shift 2
            ;;
        --direction)
            DIRECTION="$2"
            shift 2
            ;;
        --help|-h)
            cmd_tree "$TOOL_NAME" "Render.com log viewer" "$(jq -n '[
                {name: "logs", description: "Fetch logs for a service", usage: "render-logs <service-id> [--lines N] [--type app|request|build] [--level error|warn|info] [--since 1h|7d] [--start TIME] [--end TIME]"}
            ]')"
            exit 0
            ;;
        -*)
            json_error "$TOOL_NAME" "Unknown option: $1" "INVALID_ARG" "Run: render-logs --help"
            ;;
        *)
            SERVICE_ID="$1"
            shift
            ;;
    esac
done

if [[ -z "$SERVICE_ID" ]]; then
    cmd_tree "$TOOL_NAME" "Render.com log viewer" "$(jq -n '[
        {name: "logs", description: "Fetch logs for a service", usage: "render-logs <service-id> [--lines N] [--type app|request|build] [--level error|warn|info] [--since 1h|7d]"}
    ]')"
    exit 0
fi

load_api_key || json_error "$TOOL_NAME" "RENDER_API_KEY not found" "AUTH_MISSING" "Set it in .env or ~/.config/render/api_key"

OWNER_ID=$(load_workspace) || true
if [[ -z "$OWNER_ID" ]]; then
    json_error "$TOOL_NAME" "No workspace selected" "NOT_FOUND" "Run: render-workspace select <owner-id>"
fi

# Convert relative time to RFC3339 helper
parse_relative_time() {
    local time_spec="$1"
    local result=""

    if [[ "$time_spec" =~ ^[0-9]{4}- ]]; then
        echo "$time_spec"
        return 0
    elif [[ "$time_spec" =~ ^([0-9]+)d$ ]]; then
        local days="${BASH_REMATCH[1]}"
        result=$(date -u -v-"${days}d" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || \
                 date -u -d "${days} days ago" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    elif [[ "$time_spec" =~ ^([0-9]+)h$ ]]; then
        local hours="${BASH_REMATCH[1]}"
        result=$(date -u -v-"${hours}H" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || \
                 date -u -d "${hours} hours ago" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    elif [[ "$time_spec" =~ ^([0-9]+)m$ ]]; then
        local mins="${BASH_REMATCH[1]}"
        result=$(date -u -v-"${mins}M" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || \
                 date -u -d "${mins} minutes ago" +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || echo "")
    fi

    if [[ -n "$result" ]]; then
        echo "$result"
        return 0
    fi
    return 1
}

# Handle --since: converts to startTime with forward direction
if [[ -n "$SINCE" ]]; then
    COMPUTED_START_TIME=$(parse_relative_time "$SINCE") || \
        json_error "$TOOL_NAME" "Could not parse time: $SINCE" "INVALID_ARG" "Use relative time like '1h', '30m', '7d' or RFC3339 format"
    START_TIME="$COMPUTED_START_TIME"
    if [[ -z "$DIRECTION" ]]; then
        DIRECTION="forward"
    fi
fi

# Default direction is backward if not set
if [[ -z "$DIRECTION" ]]; then
    DIRECTION="backward"
fi

# Build query params
PARAMS="ownerId=$OWNER_ID&resource=$SERVICE_ID&limit=$LINES&direction=$DIRECTION"

if [[ -n "$LOG_TYPE" ]]; then
    PARAMS="$PARAMS&type=$LOG_TYPE"
fi

if [[ -n "$LOG_LEVEL" ]]; then
    PARAMS="$PARAMS&level=$LOG_LEVEL"
fi

if [[ -n "$START_TIME" ]]; then
    PARAMS="$PARAMS&startTime=$START_TIME"
fi

if [[ -n "$END_TIME" ]]; then
    PARAMS="$PARAMS&endTime=$END_TIME"
fi

# Fetch logs
raw=$(render_api "/logs?$PARAMS")

# Parse log entries into structured JSON
entries=$(echo "$raw" | jq '[.logs[]? | {
    timestamp: (.timestamp | split(".")[0] + "Z"),
    level: ((.labels // [])[] | select(.name=="level") | .value) // "info",
    message: .message
}]')

# Truncate
truncated=$(json_truncate "$entries" "$LINES")

local_na=$(next_actions \
    "$(next_action "render-logs $SERVICE_ID --lines 100" "Show more log lines")" \
    "$(next_action "render-logs $SERVICE_ID --level error" "Show only errors")" \
    "$(next_action "render-services get $SERVICE_ID" "Get service details")")

json_ok "$TOOL_NAME" "$truncated" "$local_na"

#!/usr/bin/env bash
# codex-ask — lightweight Codex API call (no agent loop)
#
# Single mode:
#   codex-ask "prompt"
#   echo "prompt" | codex-ask
#   codex-ask --reasoning medium "prompt"
#
# Batch mode (parallel over single HTTP/2 connection):
#   codex-ask --batch prompts.jsonl
#   codex-ask --batch prompts.jsonl --parallel-max 10
#
# Batch input:  JSONL with {"id": "...", "prompt": "..."}
# Batch output: JSONL with {"id": "...", "response": "...", "tokens_in": N, "tokens_out": N}
#
# Calls the OpenAI Responses API directly, skipping the full
# codex exec agent machinery. ~10-30s instead of minutes.

set -euo pipefail

REASONING="xhigh"
MODEL="gpt-5.3-codex"
BATCH_FILE=""
PARALLEL_MAX=10
MAX_RETRIES=3

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --reasoning) REASONING="$2"; shift 2 ;;
    --model) MODEL="$2"; shift 2 ;;
    --batch) BATCH_FILE="$2"; shift 2 ;;
    --parallel-max) PARALLEL_MAX="$2"; shift 2 ;;
    --retries) MAX_RETRIES="$2"; shift 2 ;;
    --help|-h)
      cat <<'USAGE'
Usage:
  codex-ask [OPTIONS] "prompt"
  echo "prompt" | codex-ask [OPTIONS]
  codex-ask --batch FILE [OPTIONS]

Options:
  --reasoning LEVEL   xhigh|high|medium|low (default: xhigh)
  --model MODEL       Model name (default: gpt-5.3-codex)
  --batch FILE        JSONL file with {"id","prompt"} per line
  --parallel-max N    Max concurrent requests in batch (default: 10)
  --retries N         Max retries on 429/5xx (default: 3)

Single mode outputs plain text. Batch mode outputs JSONL.
USAGE
      exit 0
      ;;
    *) break ;;
  esac
done

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "Error: OPENAI_API_KEY not set" >&2
  exit 1
fi

API_URL="https://api.openai.com/v1/responses"

# ── Single mode ──────────────────────────────────────────────

single_call() {
  local prompt="$1"

  PAYLOAD=$(jq -n \
    --arg model "$MODEL" \
    --arg prompt "$prompt" \
    --arg effort "$REASONING" \
    '{
      model: $model,
      input: $prompt,
      reasoning: { effort: $effort }
    }')

  local attempt=0 delay=1
  while (( attempt < MAX_RETRIES )); do
    RESPONSE=$(curl -sS -w "\n%{http_code}" \
      --http2 \
      "$API_URL" \
      -H "Authorization: Bearer $OPENAI_API_KEY" \
      -H "Content-Type: application/json" \
      -d "$PAYLOAD")

    HTTP_CODE=$(echo "$RESPONSE" | tail -1)
    BODY=$(echo "$RESPONSE" | sed '$d')

    if [[ "$HTTP_CODE" == "200" ]]; then
      break
    elif [[ "$HTTP_CODE" == "429" || "$HTTP_CODE" =~ ^5 ]]; then
      attempt=$((attempt + 1))
      if (( attempt >= MAX_RETRIES )); then
        echo "Error: API returned HTTP $HTTP_CODE after $MAX_RETRIES attempts" >&2
        echo "$BODY" | jq -r '.error.message // .' >&2
        exit 1
      fi
      sleep "$delay"
      delay=$((delay * 2))
    else
      echo "Error: API returned HTTP $HTTP_CODE" >&2
      echo "$BODY" | jq -r '.error.message // .' >&2
      exit 1
    fi
  done

  TEXT=$(echo "$BODY" | jq -r '.output[] | select(.type == "message") | .content[] | select(.type == "output_text") | .text' 2>/dev/null)
  INPUT_TOKENS=$(echo "$BODY" | jq -r '.usage.input_tokens // "?"' 2>/dev/null)
  OUTPUT_TOKENS=$(echo "$BODY" | jq -r '.usage.output_tokens // "?"' 2>/dev/null)

  if [[ -z "$TEXT" ]]; then
    echo "Error: could not extract response text" >&2
    echo "$BODY" | jq '.' >&2
    exit 1
  fi

  echo "$TEXT"
  echo ""
  echo "---"
  echo "Model: $MODEL | Reasoning: $REASONING | Tokens: $INPUT_TOKENS in / $OUTPUT_TOKENS out"
}

# ── Batch mode ───────────────────────────────────────────────

batch_call() {
  local batch_file="$1"

  if [[ ! -f "$batch_file" ]]; then
    echo "Error: batch file not found: $batch_file" >&2
    exit 1
  fi

  local tmpdir
  tmpdir=$(mktemp -d)
  trap 'rm -rf "$tmpdir"' EXIT

  # Build curl config for --parallel
  local config="$tmpdir/curl.cfg"
  local line_num=0

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" ]] && continue

    local id prompt payload
    id=$(echo "$line" | jq -r '.id // empty')
    prompt=$(echo "$line" | jq -r '.prompt // empty')

    if [[ -z "$id" || -z "$prompt" ]]; then
      echo "Warning: skipping malformed line: $line" >&2
      continue
    fi

    payload=$(jq -n \
      --arg model "$MODEL" \
      --arg prompt "$prompt" \
      --arg effort "$REASONING" \
      '{
        model: $model,
        input: $prompt,
        reasoning: { effort: $effort }
      }')

    # Write payload to a file (curl --data @file avoids shell escaping)
    echo "$payload" > "$tmpdir/payload_${line_num}.json"

    # Write curl config entry
    cat >> "$config" <<EOF
url = "$API_URL"
header = "Authorization: Bearer $OPENAI_API_KEY"
header = "Content-Type: application/json"
data = @$tmpdir/payload_${line_num}.json
output = $tmpdir/response_${line_num}.json
write-out = \\n%{http_code}\\n
next
EOF

    # Store ID mapping
    echo "$id" > "$tmpdir/id_${line_num}.txt"
    line_num=$((line_num + 1))
  done < "$batch_file"

  if (( line_num == 0 )); then
    echo "Error: no valid entries in batch file" >&2
    exit 1
  fi

  echo "Sending $line_num requests (parallel-max: $PARALLEL_MAX)..." >&2

  # Fire all requests over a single HTTP/2 connection
  curl --parallel \
    --parallel-immediate \
    --parallel-max "$PARALLEL_MAX" \
    --http2 \
    -sS \
    --config "$config" 2>/dev/null

  # Parse results and emit JSONL
  local failures=0
  for (( i=0; i<line_num; i++ )); do
    local id response_file
    id=$(cat "$tmpdir/id_${i}.txt")
    response_file="$tmpdir/response_${i}.json"

    if [[ ! -f "$response_file" ]]; then
      jq -n --arg id "$id" --arg err "no response received" \
        '{id: $id, error: $err}'
      failures=$((failures + 1))
      continue
    fi

    # Response file contains body + http_code on last line
    local body http_code
    http_code=$(tail -1 "$response_file")
    body=$(sed '$d' "$response_file")

    if [[ "$http_code" != "200" ]]; then
      local err_msg
      err_msg=$(echo "$body" | jq -r '.error.message // "unknown error"' 2>/dev/null)
      jq -n --arg id "$id" --arg err "$err_msg" --arg code "$http_code" \
        '{id: $id, error: $err, http_code: ($code | tonumber)}'
      failures=$((failures + 1))
      continue
    fi

    local text tokens_in tokens_out
    text=$(echo "$body" | jq -r '.output[] | select(.type == "message") | .content[] | select(.type == "output_text") | .text' 2>/dev/null)
    tokens_in=$(echo "$body" | jq -r '.usage.input_tokens // 0' 2>/dev/null)
    tokens_out=$(echo "$body" | jq -r '.usage.output_tokens // 0' 2>/dev/null)

    if [[ -z "$text" ]]; then
      jq -n --arg id "$id" --arg err "could not extract response text" \
        '{id: $id, error: $err}'
      failures=$((failures + 1))
      continue
    fi

    jq -n \
      --arg id "$id" \
      --arg response "$text" \
      --argjson tokens_in "$tokens_in" \
      --argjson tokens_out "$tokens_out" \
      '{id: $id, response: $response, tokens_in: $tokens_in, tokens_out: $tokens_out}'
  done

  # Summary to stderr
  local successes=$((line_num - failures))
  echo "Done: $successes/$line_num succeeded" >&2
  if (( failures > 0 )); then
    echo "Warning: $failures requests failed" >&2
  fi
}

# ── Dispatch ─────────────────────────────────────────────────

if [[ -n "$BATCH_FILE" ]]; then
  batch_call "$BATCH_FILE"
else
  # Single mode: get prompt from args or stdin
  if [[ $# -gt 0 ]]; then
    PROMPT="$*"
  elif [[ ! -t 0 ]]; then
    PROMPT="$(cat)"
  else
    echo "Error: no prompt provided" >&2
    echo "Usage: codex-ask [--reasoning LEVEL] \"prompt\"" >&2
    echo "       codex-ask --batch FILE" >&2
    exit 1
  fi
  single_call "$PROMPT"
fi

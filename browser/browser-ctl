// Structured data commands

async function execStorage(page, args) {
  const action = args[0];
  const storageType = args[1];
  const key = args[2];
  const value = args.slice(3).join(' ');

  if (!action || !storageType || !['local', 'session'].includes(storageType)) {
    throw new Error('Usage: storage <get|set|keys|clear> <local|session> [key] [value]');
  }

  const storageProp = storageType === 'local' ? 'localStorage' : 'sessionStorage';

  switch (action) {
    case 'get': {
      if (!key) throw new Error('Usage: storage get <local|session> <key>');
      const result = await page.evaluate(({ storageProp, key }) => {
        const val = window[storageProp].getItem(key);
        if (val === null) return null;
        try { return JSON.parse(val); } catch { return val; }
      }, { storageProp, key });
      if (result === null) return { output: `${c.dim}(null)${c.reset}`, data: { key, value: null, storage: storageType } };
      const output = typeof result === 'object' ? JSON.stringify(result, null, 2) : String(result);
      return { output, data: { key, value: result, storage: storageType } };
    }
    case 'set': {
      if (!key || !value) throw new Error('Usage: storage set <local|session> <key> <value>');
      await page.evaluate(({ storageProp, key, value }) => {
        window[storageProp].setItem(key, value);
      }, { storageProp, key, value });
      return { output: `${c.green}Set ${storageType}Storage["${key}"]${c.reset}`, data: { key, value, storage: storageType } };
    }
    case 'keys': {
      const keys = await page.evaluate(({ storageProp }) => {
        const keys = [];
        for (let i = 0; i < window[storageProp].length; i++) keys.push(window[storageProp].key(i));
        return keys;
      }, { storageProp });
      return { output: keys.length ? keys.join('\n') : `${c.dim}(no keys)${c.reset}`, data: { keys, storage: storageType } };
    }
    case 'clear': {
      await page.evaluate(({ storageProp }) => window[storageProp].clear(), { storageProp });
      return { output: `${c.green}Cleared ${storageType}Storage${c.reset}`, data: { storage: storageType } };
    }
    default:
      throw new Error(`Unknown storage action: ${action}. Use get, set, keys, or clear.`);
  }
}


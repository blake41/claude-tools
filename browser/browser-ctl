// Compound command: do

function parseDoSteps(args) {
  const steps = [];
  let current = [];
  for (const arg of args) {
    if (arg === ',' || arg === '--then') {
      if (current.length > 0) { steps.push(current); current = []; }
    } else {
      current.push(arg);
    }
  }
  if (current.length > 0) steps.push(current);
  return steps;
}

async function cmdDo(args) {
  const jsonOutput = args.includes('--json');
  const filteredArgs = args.filter(a => a !== '--json');
  const steps = parseDoSteps(filteredArgs);

  if (steps.length === 0) {
    console.error(`${c.red}Usage: browser-ctl do <cmd1> [args] , <cmd2> [args] , ...${c.reset}`);
    process.exit(1);
  }

  const { page, browser } = await connect();
  const results = [];

  try {
    for (let i = 0; i < steps.length; i++) {
      const [cmd, ...cmdArgs] = steps[i];
      const execFn = EXEC_DISPATCH[cmd];

      if (!execFn) {
        throw new Error(`Unknown command in step ${i + 1}: "${cmd}"`);
      }

      const result = await execFn(page, cmdArgs);
      results.push({ step: i + 1, command: cmd, ok: true, data: result.data });

      if (!jsonOutput) {
        if (steps.length > 1) {
          console.log(`${c.dim}--- [${i + 1}/${steps.length}] ${cmd} ${cmdArgs.join(' ')} ---${c.reset}`);
        }
        console.log(result.output);
      }
    }

    if (jsonOutput) {
      console.log(JSON.stringify(results, null, 2));
    }
  } catch (err) {
    if (jsonOutput) {
      results.push({ step: results.length + 1, ok: false, error: err.message });
      console.log(JSON.stringify(results, null, 2));
    } else {
      console.error(`${c.red}Step ${results.length + 1} failed: ${err.message}${c.reset}`);
    }
    process.exit(1);
  } finally {
    await browser.close();
  }
}


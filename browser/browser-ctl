  if (!selectorOrRef || !condition) throw new Error('Usage: check <selector|ref:eN> <visible|hidden|enabled|disabled|checked>');
  const element = await resolveElement(page, selectorOrRef);
  let result;
  switch (condition) {
    case 'visible': result = await element.isVisible(); break;
    case 'hidden': result = !(await element.isVisible()); break;
    case 'enabled': result = await element.isEnabled(); break;
    case 'disabled': result = !(await element.isEnabled()); break;
    case 'checked': result = await element.isChecked(); break;
    default: throw new Error(`Unknown condition: ${condition}. Use visible, hidden, enabled, disabled, or checked.`);
  }
  return { output: String(result), data: { condition, result, selector: selectorOrRef } };
}

// Recording exec functions

async function execRecordStart(page, args) {
  // Parse args
  let outputPath = null;
  let mode = 'screencast';
  let fps = 2;
  let quality = 80;

  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--mode') {
      mode = args[++i];
      if (!['screencast', 'capture'].includes(mode)) {
        throw new Error(`Unknown recording mode: ${mode}. Use 'screencast' or 'capture'.`);
      }
    } else if (args[i] === '--fps') {
      fps = parseInt(args[++i]);
      if (isNaN(fps) || fps < 1 || fps > 30) throw new Error('FPS must be between 1 and 30');
    } else if (args[i] === '--quality') {
      quality = parseInt(args[++i]);
      if (isNaN(quality) || quality < 1 || quality > 100) throw new Error('Quality must be between 1 and 100');
    } else if (!args[i].startsWith('-')) {
      outputPath = args[i];
    }
  }

  // Check for existing/stale recordings
  const existing = cleanStaleRecording();
  if (existing) {
    throw new Error(`Recording already in progress (started ${existing.startedAt}). Use 'record stop' or 'record cancel'.`);
  }

  const timestamp = Date.now();
  const defaultExt = mode === 'capture' ? 'webm' : 'mp4';
  outputPath = outputPath || path.join(SCREENSHOT_DIR, `recording-${timestamp}.${defaultExt}`);
  if (!path.isAbsolute(outputPath)) {
    outputPath = path.resolve(outputPath);
  }

  const tabUrl = page.url();

  if (mode === 'screencast') {
    // Mode A: CDP Screencast via frame-collector daemon
    const framesDir = path.join(SCREENSHOT_DIR, `frames-${timestamp}`);
    fs.mkdirSync(framesDir, { recursive: true });

    const state = {
      mode: 'screencast',
      startedAt: new Date().toISOString(),
      outputPath,
      framesDir,
      fps,
      quality,
      frameCount: 0,
      pid: null,
      tabUrl,
    };

    writeRecordingState(state);

    // Spawn detached frame-collector
    const collectorPath = path.join(SCRIPT_DIR, 'frame-collector.js');
    const collectorArgs = [
      collectorPath,
      '--port', String(CDP_PORT),
      '--host', CDP_HOST,
      '--fps', String(fps),
      '--quality', String(quality),
      '--frames-dir', framesDir,
      '--state-file', RECORDING_STATE_FILE,
    ];

    const collector = spawn(process.execPath, collectorArgs, {
      detached: true,
      stdio: ['ignore', 'ignore', 'ignore'],
    });

    collector.unref();

    // Update state with PID
    state.pid = collector.pid;
    writeRecordingState(state);

    // Wait briefly for collector to start
    await new Promise(r => setTimeout(r, 500));

    // Verify collector is running
    if (!isProcessAlive(collector.pid)) {
      clearRecordingState();
      fs.rmSync(framesDir, { recursive: true, force: true });
      throw new Error('Frame collector failed to start. Check Chrome connection.');
    }

    const output = `${c.green}Recording started${c.reset} (screencast mode)\n` +
      `${c.dim}FPS: ${fps}, Quality: ${quality}${c.reset}\n` +
      `${c.dim}Output: ${outputPath}${c.reset}\n` +
      `${c.dim}Tab: ${tabUrl}${c.reset}\n` +
      `${c.dim}Use 'browser-ctl record stop' to finish${c.reset}`;
    return { output, data: { mode, fps, quality, outputPath, pid: collector.pid } };

  } else {
    // Mode B: tabCapture extension
    const state = {
      mode: 'capture',
      startedAt: new Date().toISOString(),
      outputPath,
      fps,
      quality,
      frameCount: 0,
      pid: process.pid,
      tabUrl,
    };

    // Find extension service worker target
    const extensionTarget = await getExtensionTarget(CDP_PORT);
    if (!extensionTarget) {
      throw new Error(
        'Tab capture extension not found. Ensure Chrome was started with:\n' +
        `  browser-open  (which loads the extension automatically)\n` +
        `Or manually add: --load-extension=${TAB_CAPTURE_EXTENSION_DIR}`
      );
    }

    // Send start message to extension
    const result = await sendExtensionMessage(CDP_PORT, extensionTarget, { action: 'startCapture' });
    if (!result || !result.ok) {
      throw new Error(`Extension start failed: ${result?.error || 'Unknown error'}`);
    }

    state.tabUrl = result.tabUrl || tabUrl;
    writeRecordingState(state);

    const output = `${c.green}Recording started${c.reset} (capture mode)\n` +
      `${c.dim}Output: ${outputPath}${c.reset}\n` +
      `${c.dim}Tab: ${state.tabUrl}${c.reset}\n` +
      `${c.dim}Use 'browser-ctl record stop' to finish${c.reset}`;
    return { output, data: { mode, outputPath } };
  }
}

async function execRecordStop(page, args) {
  const state = readRecordingState();
  if (!state) {
    throw new Error('No active recording. Use \'record start\' to begin.');
  }

  if (state.mode === 'screencast') {
    // Kill frame collector
    if (state.pid && isProcessAlive(state.pid)) {
      try {
        process.kill(state.pid, 'SIGTERM');
      } catch (e) {}
      // Wait for collector to finish
      for (let i = 0; i < 20; i++) {
        if (!isProcessAlive(state.pid)) break;
        await new Promise(r => setTimeout(r, 200));
      }
    }

    // Re-read state to get final frame count
    const finalState = readRecordingState() || state;
    const frameCount = finalState.frameCount || 0;

    if (frameCount === 0) {
      clearRecordingState();
      if (state.framesDir && fs.existsSync(state.framesDir)) {
        fs.rmSync(state.framesDir, { recursive: true, force: true });
      }
      throw new Error('No frames captured. Recording may have failed.');
    }

    const outputPath = state.outputPath;
    const fps = state.fps || 2;
    let encoded = false;
    let encodingMsg = '';

    // Try to encode with ffmpeg
    try {
      execSync('which ffmpeg', { encoding: 'utf8' });
      const ffmpegCmd = `ffmpeg -framerate ${fps} -i "${state.framesDir}/frame-%06d.jpg" -c:v libx264 -pix_fmt yuv420p -preset fast -crf 23 -y "${outputPath}" 2>&1`;
      execSync(ffmpegCmd, { encoding: 'utf8', timeout: 120000 });
      encoded = true;

      // Clean up frames
      fs.rmSync(state.framesDir, { recursive: true, force: true });
      encodingMsg = `${c.green}Video saved:${c.reset} ${outputPath}`;
    } catch (e) {
      if (e.message && e.message.includes('which ffmpeg')) {
        encodingMsg = `${c.yellow}ffmpeg not found.${c.reset} Frames saved to: ${state.framesDir}\n` +
          `${c.dim}Install: brew install ffmpeg${c.reset}\n` +
          `${c.dim}Then encode manually:${c.reset}\n` +
          `  ffmpeg -framerate ${fps} -i "${state.framesDir}/frame-%06d.jpg" -c:v libx264 -pix_fmt yuv420p -preset fast -crf 23 -y "${outputPath}"`;
      } else {
        encodingMsg = `${c.red}ffmpeg encoding failed:${c.reset} ${e.message}\n` +
          `${c.dim}Raw frames at: ${state.framesDir}${c.reset}`;
      }
    }

    clearRecordingState();

    const elapsed = Math.round((Date.now() - new Date(state.startedAt).getTime()) / 1000);
    const output = `${c.green}Recording stopped${c.reset}\n` +
      `${c.dim}Duration: ${elapsed}s, Frames: ${frameCount}${c.reset}\n` +
      encodingMsg;
    return { output, data: { frames: frameCount, outputPath: encoded ? outputPath : state.framesDir, encoded } };

  } else if (state.mode === 'capture') {
    // Mode B: stop extension recording
    const extensionTarget = await getExtensionTarget(CDP_PORT);
    if (!extensionTarget) {
      clearRecordingState();
      throw new Error('Tab capture extension not found. Recording state cleared.');
    }

    const result = await sendExtensionMessage(CDP_PORT, extensionTarget, { action: 'stopCapture' });
    if (!result || !result.ok) {
      clearRecordingState();
      throw new Error(`Extension stop failed: ${result?.error || 'Unknown error'}`);
    }

    // Write WebM data to disk
    const webmData = Buffer.from(result.data, 'base64');
    let finalPath = state.outputPath;

    // If output is .mp4, try to convert
    if (finalPath.endsWith('.mp4')) {
      const webmPath = finalPath.replace(/\.mp4$/, '.webm');
      fs.writeFileSync(webmPath, webmData);

      try {
        execSync('which ffmpeg', { encoding: 'utf8' });
        execSync(`ffmpeg -i "${webmPath}" -c:v libx264 -pix_fmt yuv420p -preset fast -crf 23 -y "${finalPath}" 2>&1`, {
          encoding: 'utf8', timeout: 120000,
        });
        fs.unlinkSync(webmPath);
      } catch (e) {
        // ffmpeg not available or failed; keep the webm
        finalPath = webmPath;
      }
    } else {
      // Write directly as webm
      if (!finalPath.endsWith('.webm')) finalPath += '.webm';
      fs.writeFileSync(finalPath, webmData);
    }

    clearRecordingState();

    const elapsed = Math.round((Date.now() - new Date(state.startedAt).getTime()) / 1000);
    const sizeMB = (webmData.length / (1024 * 1024)).toFixed(1);
    const output = `${c.green}Recording stopped${c.reset}\n` +
      `${c.dim}Duration: ${elapsed}s, Size: ${sizeMB}MB${c.reset}\n` +
      `${c.green}Video saved:${c.reset} ${finalPath}`;
    return { output, data: { outputPath: finalPath, size: webmData.length } };

  } else {
    clearRecordingState();
    throw new Error(`Unknown recording mode in state: ${state.mode}`);
  }
}

async function execRecordStatus(page, args) {
  const state = readRecordingState();
  if (!state) {
    return { output: `${c.dim}No active recording${c.reset}`, data: { recording: false } };
  }

  const elapsed = Math.round((Date.now() - new Date(state.startedAt).getTime()) / 1000);
  const minutes = Math.floor(elapsed / 60);
  const seconds = elapsed % 60;
  const timeStr = minutes > 0 ? `${minutes}m ${seconds}s` : `${seconds}s`;

  let alive = true;
  if (state.mode === 'screencast' && state.pid) {
    alive = isProcessAlive(state.pid);
  }

  // Re-read for latest frame count (collector updates this)
  const freshState = readRecordingState() || state;
  const frameCount = freshState.frameCount || 0;

  const statusIcon = alive ? `${c.green}●${c.reset}` : `${c.red}●${c.reset}`;
  const statusText = alive ? 'recording' : 'stopped (collector dead)';

  const output = `${statusIcon} ${statusText}\n` +
    `${c.dim}Mode: ${state.mode}${c.reset}\n` +
    `${c.dim}Elapsed: ${timeStr}${c.reset}\n` +
    (state.mode === 'screencast' ? `${c.dim}Frames: ${frameCount}${c.reset}\n` : '') +
    `${c.dim}Output: ${state.outputPath}${c.reset}\n` +
    `${c.dim}Tab: ${state.tabUrl || 'unknown'}${c.reset}`;
  return { output, data: { recording: true, alive, mode: state.mode, elapsed, frameCount } };
}

async function execRecordCancel(page, args) {
  const state = readRecordingState();
  if (!state) {
    return { output: `${c.dim}No active recording to cancel${c.reset}`, data: { cancelled: false } };
  }

  // Kill collector if screencast mode
  if (state.mode === 'screencast' && state.pid && isProcessAlive(state.pid)) {
    try {
      process.kill(state.pid, 'SIGTERM');
    } catch (e) {}
  }

  // Clean up frames directory
  if (state.framesDir && fs.existsSync(state.framesDir)) {
    fs.rmSync(state.framesDir, { recursive: true, force: true });
  }

  clearRecordingState();

  const output = `${c.yellow}Recording cancelled${c.reset}\n${c.dim}Temporary files cleaned up${c.reset}`;
  return { output, data: { cancelled: true } };
}

// Extension communication helpers for tab capture mode

async function getExtensionTarget(port) {
  return new Promise((resolve) => {
    http.get(`http://${CDP_HOST}:${port}/json`, (res) => {
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => {
        try {
          const targets = JSON.parse(data);
          const sw = targets.find(t =>
            t.type === 'service_worker' &&
            t.url && t.url.includes('tab-capture') &&
            t.url.includes('service-worker')
          );
          resolve(sw || null);
        } catch (e) {
          resolve(null);
        }
      });
    }).on('error', () => {
      resolve(null);
    });
  });
}

async function sendExtensionMessage(port, target, message) {
  const CDP = require('chrome-remote-interface');
  let client;
  try {
    client = await CDP({
      target: target.webSocketDebuggerUrl || target.id,
      port,
      host: CDP_HOST,
    });
    const { Runtime } = client;
    await Runtime.enable();

    // Use chrome.runtime.sendMessage to communicate with the extension
    const expr = `
      new Promise((resolve, reject) => {
        chrome.runtime.sendMessage(${JSON.stringify(message)}, (response) => {
          if (chrome.runtime.lastError) {
            reject(new Error(chrome.runtime.lastError.message));
          } else {
            resolve(response);
          }
        });
      })
    `;

    const result = await Runtime.evaluate({
      expression: expr,
      awaitPromise: true,
      returnByValue: true,
    });

    if (result.exceptionDetails) {
      throw new Error(result.exceptionDetails.text || 'Extension eval failed');
    }

    return result.result.value;
  } finally {
    if (client) {
      try { await client.close(); } catch (e) {}
    }
  }
}


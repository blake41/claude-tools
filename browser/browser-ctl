function formatSnapshotDiff(oldText, newText, contextLines, fullDiff) {
  const ctx = fullDiff ? Infinity : (contextLines || 3);
  const patch = Diff.structuredPatch('baseline', 'current', oldText, newText, '', '', { context: ctx });

  if (patch.hunks.length === 0) {
    return { output: `${c.green}No changes detected${c.reset}`, changed: false, stats: { added: 0, removed: 0 } };
  }

  let added = 0;
  let removed = 0;
  const lines = [];

  for (const hunk of patch.hunks) {
    lines.push(`${c.cyan}@@ -${hunk.oldStart},${hunk.oldLines} +${hunk.newStart},${hunk.newLines} @@${c.reset}`);
    for (const line of hunk.lines) {
      if (line.startsWith('+')) {
        lines.push(`${c.green}${line}${c.reset}`);
        added++;
      } else if (line.startsWith('-')) {
        lines.push(`${c.red}${line}${c.reset}`);
        removed++;
      } else {
        lines.push(line);
      }
    }
  }

  lines.push(`${c.dim}--- ${added} added, ${removed} removed ---${c.reset}`);
  return { output: lines.join('\n'), changed: true, stats: { added, removed } };
}

async function execDiffSnapshot(page, args) {
  let baselineFile = null;
  let contextLines = 3;
  let fullDiff = false;

  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--baseline' || args[i] === '-b') {
      baselineFile = args[++i];
    } else if (args[i] === '--context' || args[i] === '-C') {
      contextLines = parseInt(args[++i]);
    } else if (args[i] === '--full-diff') {
      fullDiff = true;
    }
  }

  let baseline;
  if (baselineFile) {
    if (!fs.existsSync(baselineFile)) throw new Error(`Baseline file not found: ${baselineFile}`);
    baseline = fs.readFileSync(baselineFile, 'utf8');
  } else {
    baseline = readSnapshotCache();
    if (!baseline) throw new Error('No baseline available. Run "browser-ctl snapshot" first, or pass --baseline FILE');
  }

  const freshResult = await execSnapshot(page, []);
  const freshSnapshot = freshResult.data;

  const diff = formatSnapshotDiff(baseline, freshSnapshot, contextLines, fullDiff);
  return { output: diff.output, data: { changed: diff.changed, stats: diff.stats } };
}

async function execDiffScreenshot(page, args) {
  let baselineFile = null;
  let outputFile = null;
  let threshold = 0.1;
  let selector = null;
  let fullPage = false;

  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--baseline' || args[i] === '-b') {
      baselineFile = args[++i];
    } else if (args[i] === '--output' || args[i] === '-o') {
      outputFile = args[++i];
    } else if (args[i] === '--threshold' || args[i] === '-t') {
      threshold = parseFloat(args[++i]);
    } else if (args[i] === '--selector' || args[i] === '-s') {
      selector = args[++i];
    } else if (args[i] === '--full' || args[i] === '-f') {
      fullPage = true;
    }
  }

  if (!baselineFile) throw new Error('Usage: diff screenshot --baseline FILE [--output FILE] [--threshold 0-1] [--selector SEL] [--full]');
  if (!fs.existsSync(baselineFile)) throw new Error(`Baseline file not found: ${baselineFile}`);

  // Check for ImageMagick compare
  try {
    execSync('which compare', { encoding: 'utf8', stdio: 'pipe' });
  } catch (e) {
    throw new Error('ImageMagick "compare" not found. Install with: brew install imagemagick');
  }

  // Take fresh screenshot
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
  const tempScreenshot = path.join(SCREENSHOT_DIR, `diff-current-${timestamp}.png`);
  const screenshotArgs = ['--output', tempScreenshot, '--no-resize'];
  if (selector) screenshotArgs.push('--selector', selector);
  if (fullPage) screenshotArgs.push('--full');
  await execScreenshot(page, screenshotArgs);

  // Output diff image path
  outputFile = outputFile || path.join(SCREENSHOT_DIR, `diff-result-${timestamp}.png`);
  const fuzzPercent = Math.round(threshold * 100);

  // Run ImageMagick compare
  let diffPixels = 0;
  try {
    const result = execSync(
      `compare -metric AE -fuzz ${fuzzPercent}% "${baselineFile}" "${tempScreenshot}" "${outputFile}" 2>&1`,
      { encoding: 'utf8', stdio: 'pipe' }
    );
    diffPixels = parseInt(result.trim()) || 0;
  } catch (e) {
    // Exit code 1 means images differ (normal), exit code 2 means error
    if (e.status === 2) {
      throw new Error(`ImageMagick compare failed: ${e.stderr || e.stdout || e.message}`);
    }
    // Exit code 1: images differ, pixel count is in stderr/stdout
    const output = (e.stderr || e.stdout || '').trim();
    diffPixels = parseInt(output) || 0;
  }

  // Get dimensions via sips
  let width = 0, height = 0;
  try {
    const info = execSync(`sips -g pixelWidth -g pixelHeight "${tempScreenshot}" 2>/dev/null`, { encoding: 'utf8' });
    width = parseInt(info.match(/pixelWidth:\s*(\d+)/)?.[1] || '0');
    height = parseInt(info.match(/pixelHeight:\s*(\d+)/)?.[1] || '0');
  } catch (e) {}

  const totalPixels = width * height;
  const percentage = totalPixels > 0 ? ((diffPixels / totalPixels) * 100).toFixed(2) : '0.00';
  const changed = diffPixels > 0;

  const lines = [];
  if (changed) {
    lines.push(`${c.yellow}Screenshots differ${c.reset}`);
  } else {
    lines.push(`${c.green}Screenshots match${c.reset}`);
  }
  lines.push(`${c.dim}Diff pixels:${c.reset} ${diffPixels} (${percentage}%)`);
  lines.push(`${c.dim}Threshold:${c.reset} ${fuzzPercent}%`);
  lines.push(`${c.dim}Diff image:${c.reset} ${outputFile}`);
  lines.push(`${c.dim}Current:${c.reset} ${tempScreenshot}`);

  return {
    output: lines.join('\n'),
    data: { changed, diffPixels, percentage: parseFloat(percentage), diffImage: outputFile, currentImage: tempScreenshot }
  };
}

async function execDiffUrl(page, args) {
  let urls = [];
  let doScreenshot = false;
  let fullPage = false;
  let selector = null;
  let contextLines = 3;
  let fullDiff = false;

  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--screenshot' || args[i] === '--ss') {
      doScreenshot = true;
    } else if (args[i] === '--full' || args[i] === '-f') {
      fullPage = true;
    } else if (args[i] === '--selector' || args[i] === '-s') {
      selector = args[++i];
    } else if (args[i] === '--context' || args[i] === '-C') {
      contextLines = parseInt(args[++i]);
    } else if (args[i] === '--full-diff') {
      fullDiff = true;
    } else if (!args[i].startsWith('-')) {
      urls.push(args[i]);
    }
  }

  if (urls.length < 2) throw new Error('Usage: diff url <URL1> <URL2> [--screenshot] [--full] [--selector SEL] [--context N] [--full-diff]');

  const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, -5);
  const outputParts = [];

  // Navigate to URL1
  await page.goto(urls[0], { waitUntil: 'domcontentloaded', timeout: 30000 });
  const snap1Result = await execSnapshot(page, []);
  const snap1 = snap1Result.data;

  let ss1Path = null;
  if (doScreenshot) {
    ss1Path = path.join(SCREENSHOT_DIR, `diff-url1-${timestamp}.png`);
    const ssArgs = ['--output', ss1Path, '--no-resize'];
    if (selector) ssArgs.push('--selector', selector);
    if (fullPage) ssArgs.push('--full');
    await execScreenshot(page, ssArgs);
  }

  // Navigate to URL2
  await page.goto(urls[1], { waitUntil: 'domcontentloaded', timeout: 30000 });
  const snap2Result = await execSnapshot(page, []);
  const snap2 = snap2Result.data;

  let ss2Path = null;
  if (doScreenshot) {
    ss2Path = path.join(SCREENSHOT_DIR, `diff-url2-${timestamp}.png`);
    const ssArgs = ['--output', ss2Path, '--no-resize'];
    if (selector) ssArgs.push('--selector', selector);
    if (fullPage) ssArgs.push('--full');
    await execScreenshot(page, ssArgs);
  }

  // Diff snapshots
  outputParts.push(`${c.cyan}--- Snapshot diff ---${c.reset}`);
  outputParts.push(`${c.dim}URL1: ${urls[0]}${c.reset}`);
  outputParts.push(`${c.dim}URL2: ${urls[1]}${c.reset}`);
  const snapshotDiff = formatSnapshotDiff(snap1, snap2, contextLines, fullDiff);
  outputParts.push(snapshotDiff.output);

  // Optionally diff screenshots
  let screenshotData = null;
  if (doScreenshot && ss1Path && ss2Path) {
    outputParts.push('');
    outputParts.push(`${c.cyan}--- Screenshot diff ---${c.reset}`);

    try {
      execSync('which compare', { encoding: 'utf8', stdio: 'pipe' });

      const diffImage = path.join(SCREENSHOT_DIR, `diff-url-result-${timestamp}.png`);
      let diffPixels = 0;
      try {
        const result = execSync(
          `compare -metric AE -fuzz 10% "${ss1Path}" "${ss2Path}" "${diffImage}" 2>&1`,
          { encoding: 'utf8', stdio: 'pipe' }
        );
        diffPixels = parseInt(result.trim()) || 0;
      } catch (e) {
        if (e.status === 2) {
          outputParts.push(`${c.red}ImageMagick compare failed: ${e.stderr || e.stdout || e.message}${c.reset}`);
        } else {
          diffPixels = parseInt((e.stderr || e.stdout || '').trim()) || 0;
        }
      }

      let width = 0, height = 0;
      try {
        const info = execSync(`sips -g pixelWidth -g pixelHeight "${ss1Path}" 2>/dev/null`, { encoding: 'utf8' });
        width = parseInt(info.match(/pixelWidth:\s*(\d+)/)?.[1] || '0');
        height = parseInt(info.match(/pixelHeight:\s*(\d+)/)?.[1] || '0');
      } catch (e) {}

      const totalPixels = width * height;
      const percentage = totalPixels > 0 ? ((diffPixels / totalPixels) * 100).toFixed(2) : '0.00';

      outputParts.push(`${c.dim}Diff pixels:${c.reset} ${diffPixels} (${percentage}%)`);
      outputParts.push(`${c.dim}Diff image:${c.reset} ${diffImage}`);
      screenshotData = { diffPixels, percentage: parseFloat(percentage), diffImage, url1Image: ss1Path, url2Image: ss2Path };
    } catch (e) {
      outputParts.push(`${c.yellow}ImageMagick "compare" not found. Install with: brew install imagemagick${c.reset}`);
      outputParts.push(`${c.dim}URL1 screenshot:${c.reset} ${ss1Path}`);
      outputParts.push(`${c.dim}URL2 screenshot:${c.reset} ${ss2Path}`);
    }
  }

  return {
    output: outputParts.join('\n'),
    data: { snapshotDiff: { changed: snapshotDiff.changed, stats: snapshotDiff.stats }, screenshot: screenshotData }
  };
}


#!/bin/bash
# browser-open - Open URLs in persistent Dev Chrome instances
#
# Usage:
#   browser-open                              # Open localhost:5173 in default profile
#   browser-open http://localhost:3000        # Open specific URL
#   browser-open --profile work https://...   # Use work profile (port 9223)
#   browser-open --profile personal https://...  # Use personal profile (port 9224)
#
# Profiles run as separate Chrome instances with their own ports.

set -eo pipefail

# Profile configuration
get_port_for_profile() {
    case "$1" in
        default)  echo 9222 ;;
        work)     echo 9223 ;;
        personal) echo 9224 ;;
        *)        echo "" ;;
    esac
}

PROFILE_BASE_DIR="$HOME/.chrome-dev-profiles"

# Defaults
PROFILE="default"
URL="http://localhost:5173"

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --profile)
            PROFILE="${2:-}"
            shift 2
            ;;
        --port|-p)
            # Legacy support - just ignore, we use profiles now
            shift 2
            ;;
        --force|-f)
            # Deprecated: kept for backwards compatibility
            shift
            ;;
        --list)
            echo "Available profiles:"
            for p in default work personal; do
                port=$(get_port_for_profile "$p")
                status="stopped"
                if curl -s "http://localhost:$port/json/version" > /dev/null 2>&1; then
                    status="running"
                fi
                printf "  %-12s port %-5s (%s)\n" "$p" "$port" "$status"
            done
            exit 0
            ;;
        --help|-h)
            cat <<EOF
browser-open - Open URLs in persistent Dev Chrome instances

USAGE
  browser-open [options] [URL]

OPTIONS
  --profile NAME   Use named profile (default, work, personal)
  --list           List available profiles and their status
  --help, -h       Show this help

PROFILES
  default    Port 9222 - General development
  work       Port 9223 - Work Google account
  personal   Port 9224 - Personal Google account

EXAMPLES
  browser-open                                # Open localhost:5173 in default
  browser-open http://localhost:3000          # Open specific URL
  browser-open --profile work https://app.example.com
  browser-open --list                         # Show profile status

NOTES
  Each profile runs as a separate Chrome instance with its own:
  - Cookies/sessions (sign into different Google accounts)
  - Extensions
  - Browsing history

  Profiles are stored in ~/.chrome-dev-profiles/<name>/
  Use 'browser-ctl --profile <name>' to control specific profiles.
EOF
            exit 0
            ;;
        http://*|https://*)
            URL="$1"
            shift
            ;;
        localhost:*)
            URL="http://$1"
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

# Validate profile
PORT=$(get_port_for_profile "$PROFILE")
if [[ -z "$PORT" ]]; then
    echo "Unknown profile: $PROFILE" >&2
    echo "Available profiles: default, work, personal" >&2
    exit 1
fi

PROFILE_DIR="$PROFILE_BASE_DIR/$PROFILE"

# Ensure profile directory exists
mkdir -p "$PROFILE_DIR"

# Resolve symlinks to get real script directory
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" || echo "$0")")" && pwd)"
# PID file uses port number to match log-collector.js
PID_FILE="/tmp/browser-log-collector-$PORT.pid"
# Tab capture extension for browser-ctl record
TAB_CAPTURE_EXT="$SCRIPT_DIR/extensions/tab-capture"

# Start log collector if not running
start_collector() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        return 0  # Already running
    fi
    # Kill any orphaned collectors for this profile
    pkill -f "log-collector.js.*--port $PORT" 2>/dev/null || true
    # Start collector in background with proper detachment
    ( cd "$SCRIPT_DIR" && node log-collector.js --port "$PORT" >> "/tmp/browser-log-collector-$PROFILE.log" 2>&1 ) &
    disown
    sleep 1
    if [[ -f "$PID_FILE" ]]; then
        return 0
    else
        echo "⚠️  Log collector failed to start. Check /tmp/browser-log-collector-$PROFILE.log"
        return 1
    fi
}

# Check if this profile's Chrome is running
if curl -s "http://localhost:$PORT/json/version" > /dev/null 2>&1; then
    echo "✓ Dev Chrome ($PROFILE) running on port $PORT"
    echo "  Opening: $URL"
    curl -s "http://localhost:$PORT/json/new?$URL" > /dev/null
    start_collector
    echo ""
    echo "Logs: browser-ctl --profile $PROFILE logs"
    exit 0
fi

# Chrome not running - start it
echo "Starting Dev Chrome ($PROFILE) on port $PORT..."
# Launch Chrome binary directly to ensure separate instance from personal Chrome
# --no-sandbox required when launching directly (not via LaunchServices) for dev use
# Build extension flags if tab-capture extension exists
EXT_FLAGS=""
if [[ -d "$TAB_CAPTURE_EXT" ]]; then
    EXT_FLAGS="--load-extension=$TAB_CAPTURE_EXT"
fi

"/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
    --remote-debugging-port="$PORT" \
    --user-data-dir="$PROFILE_DIR" \
    --no-first-run \
    --no-default-browser-check \
    --no-sandbox \
    $EXT_FLAGS &
disown

# Wait for debugging port to become available
echo -n "Waiting for Dev Chrome..."
for i in {1..20}; do
    if curl -s "http://localhost:$PORT/json/version" > /dev/null 2>&1; then
        echo " ready!"
        echo "  Opening: $URL"
        curl -s "http://localhost:$PORT/json/new?$URL" > /dev/null
        start_collector
        echo ""
        echo "Logs: browser-ctl --profile $PROFILE logs"
        exit 0
    fi
    echo -n "."
    sleep 0.5
done

echo ""
echo "⚠️  Dev Chrome ($PROFILE) failed to start after 10 seconds."

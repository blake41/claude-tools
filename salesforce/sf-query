#!/usr/bin/env bash
# sf-query - Agent-safe Salesforce SOQL queries
# SOQL is inherently read-only, no write protection needed

set -euo pipefail

REAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$REAL_SCRIPT")"
source "$SCRIPT_DIR/../cli-envelope.sh"

TOOL_NAME="sf-query"

# Environment to org alias mapping
declare -A ORG_ALIASES=(
  [prod]="vscodeOrg"
  [production]="vscodeOrg"
  [sandbox]="MySandbox"
  [clayuni]="MySandbox"
)

# Resolve environment to org alias
get_org_alias() {
  local env="${1,,}"  # lowercase
  if [[ -v "ORG_ALIASES[$env]" ]]; then
    echo "${ORG_ALIASES[$env]}"
  else
    json_error "$TOOL_NAME" "Unknown environment: $1. Valid: ${!ORG_ALIASES[*]}" "UNKNOWN_ENV" "Use one of: prod, production, sandbox, clayuni"
  fi
}

# Check sf CLI is available
if ! command -v sf &>/dev/null; then
    json_error "$TOOL_NAME" "Salesforce CLI (sf) not installed" "MISSING_DEP" "Install with: npm install -g @salesforce/cli"
fi

# Main
if [[ $# -lt 2 ]]; then
    cmd_tree "$TOOL_NAME" "Safe Salesforce SOQL queries for AI agents" "$(jq -n '[
        {name: "query", description: "Run a SOQL query", usage: "sf-query <environment> \"SELECT ...\""},
        {name: "describe", description: "Describe an object fields", usage: "sf-query <environment> describe <ObjectName>"}
    ]')"
    exit 0
fi

ENV="$1"
shift

ORG_ALIAS=$(get_org_alias "$ENV")

# Handle describe command
if [[ "$1" == "describe" ]]; then
    [[ $# -lt 2 ]] && json_error "$TOOL_NAME describe" "Object name required" "MISSING_ARG" "Usage: sf-query $ENV describe <ObjectName>"
    OBJECT="$2"

    local_result=$(sf sobject describe --sobject "$OBJECT" --target-org "$ORG_ALIAS" --json 2>/dev/null) || \
        json_error "$TOOL_NAME describe" "Failed to describe $OBJECT" "API_ERROR" "Check that the object name is correct and your org is authenticated"

    fields=$(echo "$local_result" | jq '.result.fields | map({name, type, label, length, picklistValues: (.picklistValues // [] | map(.value))})')

    na=$(next_actions \
        "$(next_action "sf-query $ENV \"SELECT Id, Name FROM $OBJECT LIMIT 10\"" "Query $OBJECT records")")

    json_ok "$TOOL_NAME describe" "$fields" "$na"
    exit 0
fi

QUERY="$1"

# Validate it looks like a SELECT query
if [[ ! "$QUERY" =~ ^[[:space:]]*(SELECT|select) ]]; then
    json_error "$TOOL_NAME query" "Query must start with SELECT. Got: $QUERY" "INVALID_QUERY" "SOQL queries must begin with SELECT"
fi

# Run query and extract records
RESULT=$(sf data query --query "$QUERY" --target-org "$ORG_ALIAS" --json 2>/dev/null) || \
    json_error "$TOOL_NAME query" "Query execution failed" "API_ERROR" "Check your SOQL syntax and org authentication"

# Check for errors
if echo "$RESULT" | jq -e '.status != 0' > /dev/null 2>&1; then
    local_msg=$(echo "$RESULT" | jq -r '.message // .result.message // "Unknown error"')
    json_error "$TOOL_NAME query" "$local_msg" "INVALID_QUERY" "Check your SOQL syntax"
fi

# Output records (or totalSize for COUNT queries)
RECORDS=$(echo "$RESULT" | jq '.result.records')
TOTAL_SIZE=$(echo "$RESULT" | jq '.result.totalSize')

if [[ "$RECORDS" == "[]" && "$TOTAL_SIZE" != "0" && "$TOTAL_SIZE" != "null" ]]; then
    # COUNT() query - return the count
    count_result=$(jq -n --argjson count "$TOTAL_SIZE" '{count: $count}')
    na=$(next_actions \
        "$(next_action "sf-query $ENV \"SELECT Id FROM ... LIMIT 10\"" "Fetch actual records")")
    json_ok "$TOOL_NAME query" "$count_result" "$na"
else
    # Truncate at 50 records
    truncated=$(json_truncate "$RECORDS" 50)
    na=$(next_actions \
        "$(next_action "sf-query $ENV describe <ObjectName>" "Describe an object's fields")")
    json_ok "$TOOL_NAME query" "$truncated" "$na"
fi

#!/usr/bin/env bash
#
# ab — safe wrapper around agent-browser
#
# Minimal wrapper that:
#   1. Ensures Chrome is running with CDP on port 9222
#   2. Passes every command through with --cdp 9222
#   3. Blocks `close` (corrupts profile)
#
# Let agent-browser handle daemon lifecycle. Don't kill daemons manually —
# they maintain tab state (active_page_index, CDP session IDs).
#
# Session isolation via AB_SUBAGENT_SESSION_ID:
#   Each unique ID gets its own daemon process (--session ab-<id>) and its
#   own Chrome tab (created via `tab new` on first open). Daemons are
#   independent — no tab switching, no races between parallel agents.

set -euo pipefail

CDP_PORT=9222
CHROME_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
CHROME_PROFILE="$HOME/.agent-browser/profile"
CHROME_PIDFILE="/tmp/ab-chrome-${CDP_PORT}.pid"
AUTH_STATE="$HOME/.agent-browser/terra-auth.json"
SEED_ORIGINS=("http://localhost:5173" "https://slack-feedback-staging.onrender.com" "https://terra.clay.com")
DASHBOARD_PORT=4848
DASHBOARD_PIDFILE="$HOME/.agent-browser/dashboard.pid"

# Headless by default. Set AB_HEADED=1 or pass --headed to show the window.
HEADED=0
if [[ "${AB_HEADED:-}" == "1" ]]; then HEADED=1; fi

# --- Blocked commands ---
if [[ "${1:-}" == "close" ]]; then
  echo "✗ BLOCKED: 'close' corrupts the browser profile. Use 'ab heal'." >&2
  exit 1
fi

# --- Check if CDP port is listening ---
_cdp_is_up() {
  curl -s --max-time 2 "http://127.0.0.1:${CDP_PORT}/json/version" >/dev/null 2>&1
}

# --- Ensure Chrome is running with CDP ---
_ensure_chrome() {
  _cdp_is_up && return 0

  # Note: Chrome launches fine inside Seatbelt sandbox as long as
  # ~/.agent-browser, ~/Library/Caches, ~/Library/Application Support, and /tmp are writable

  local headless_flag=""
  if [[ "$HEADED" == "0" ]]; then
    headless_flag="--headless=new"
    echo "▶ Launching Chrome headless on CDP port $CDP_PORT..." >&2
  else
    echo "▶ Launching Chrome headed on CDP port $CDP_PORT..." >&2
  fi
  "$CHROME_BIN" \
    --remote-debugging-port="$CDP_PORT" \
    --user-data-dir="$CHROME_PROFILE" \
    $headless_flag \
    --no-first-run --no-default-browser-check \
    --disable-background-networking --disable-backgrounding-occluded-windows \
    --disable-component-update --disable-domain-reliability --disable-sync \
    --metrics-recording-only --disable-machine-learning-model-loader \
    --disable-client-side-phishing-detection --safebrowsing-disable-auto-update \
    "about:blank" >/dev/null 2>&1 &
  echo "$!" > "$CHROME_PIDFILE"

  local tries=0
  while ! _cdp_is_up && [[ $tries -lt 15 ]]; do sleep 1; tries=$((tries+1)); done
  if _cdp_is_up; then
    echo "✓ Chrome ready (CDP port $CDP_PORT)" >&2
    # Ensure dashboard is running alongside Chrome
    _dashboard_is_up || _dashboard_start 2>/dev/null
  else
    echo "✗ Chrome not responding" >&2
    return 1
  fi
}

# --- Open URL with session isolation ---
# Each AB_SUBAGENT_SESSION_ID gets its own daemon (--session) AND its own tab.
# First open creates a new tab in that daemon; subsequent opens reuse it.
_open_with_context() {
  local url="$1"
  if [[ ${#SESSION_ARGS[@]} -eq 0 ]]; then
    # No session — just open in default daemon's default tab
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" open "$url"
    return
  fi

  # Check if this daemon already has a tab (tab list returns data)
  local tab_count
  tab_count=$(AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" "${SESSION_ARGS[@]}" tab list --json 2>/dev/null \
    | python3 -c "import json,sys; print(len(json.load(sys.stdin).get('data',{}).get('tabs',[])))" 2>/dev/null || echo "0")

  if [[ "$tab_count" -le 1 ]]; then
    # First open for this session — create a dedicated tab
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" "${SESSION_ARGS[@]}" tab new >/dev/null 2>&1
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" "${SESSION_ARGS[@]}" set viewport 1440 900 2 >/dev/null 2>&1
  fi

  AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" "${SESSION_ARGS[@]}" open "$url"
}

# --- Dashboard: manage the agent-browser dashboard ---
_dashboard_is_up() {
  curl -s --max-time 2 "http://127.0.0.1:${DASHBOARD_PORT}/" >/dev/null 2>&1
}

_dashboard_start() {
  if _dashboard_is_up; then
    echo "✓ Dashboard already running on port $DASHBOARD_PORT" >&2
    return 0
  fi

  echo "▶ Starting dashboard on port $DASHBOARD_PORT..." >&2
  agent-browser dashboard start --port "$DASHBOARD_PORT" >/dev/null 2>&1
  sleep 1

  if _dashboard_is_up; then
    echo "✓ Dashboard running at http://127.0.0.1:${DASHBOARD_PORT}" >&2
  else
    echo "✗ Dashboard failed to start" >&2
    return 1
  fi
}

_dashboard_stop() {
  if [[ -f "$DASHBOARD_PIDFILE" ]]; then
    local p; p="$(cat "$DASHBOARD_PIDFILE")"
    if kill -0 "$p" 2>/dev/null; then
      kill "$p" 2>/dev/null
      echo "✓ Dashboard stopped (PID $p)" >&2
    fi
    rm -f "$DASHBOARD_PIDFILE"
  else
    # Try to find and kill by port
    local pid
    pid=$(lsof -ti :"$DASHBOARD_PORT" 2>/dev/null | head -1)
    if [[ -n "$pid" ]]; then
      kill "$pid" 2>/dev/null
      echo "✓ Dashboard stopped (PID $pid)" >&2
    else
      echo "  Dashboard not running" >&2
    fi
  fi
}

_dashboard() {
  case "${1:-}" in
    start)   _dashboard_start ;;
    stop)    _dashboard_stop ;;
    restart) _dashboard_stop; sleep 1; _dashboard_start ;;
    status)
      if _dashboard_is_up; then
        echo "Dashboard: ✓ http://127.0.0.1:${DASHBOARD_PORT}" >&2
      else
        echo "Dashboard: ✗ not running" >&2
      fi
      ;;
    *)
      echo "Usage: ab dashboard <start|stop|restart|status>" >&2
      return 1
      ;;
  esac
}

# --- Seed: set app-level localStorage defaults ---
_seed() {
  _ensure_chrome || return 1
  echo "▶ Seeding localStorage defaults..." >&2

  # Set renderer=v4 on each origin
  for origin in "${SEED_ORIGINS[@]}"; do
    echo "  Setting terra:renderer=v4 on $origin" >&2
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" open "$origin" 2>/dev/null
    # Wait for page to be interactive enough for localStorage access
    sleep 2
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" eval 'localStorage.setItem("terra:renderer", "v4"); "ok"' 2>/dev/null \
      && echo "    ✓ Set" >&2 || echo "    ✗ Failed (page may need auth first)" >&2
  done

  # Return to blank page
  AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" open "about:blank" 2>/dev/null
  echo "✓ Seeded" >&2
}

# --- Reauth: grab cookies from user's personal Chrome ---
_reauth() {
  _ensure_chrome || return 1
  echo "▶ Grabbing auth from your personal Chrome..." >&2

  local tmp_state="/tmp/ab-reauth-$$.json"

  # Connect to user's personal Chrome and export state
  # Use a separate session to avoid contaminating the default daemon
  if ! agent-browser --auto-connect --session reauth-tmp state save "$tmp_state" 2>/dev/null; then
    echo "✗ Could not connect to your personal Chrome." >&2
    echo "  Make sure Chrome is running with at least one tab open." >&2
    return 1
  fi
  # Kill the temporary daemon immediately so it doesn't intercept future --cdp commands
  pgrep -f "agent-browser-d.*reauth-tmp" 2>/dev/null | while read -r pid; do kill "$pid" 2>/dev/null; done
  rm -f ~/.agent-browser/reauth-tmp.sock 2>/dev/null

  local cookie_count
  cookie_count=$(python3 -c "import json; d=json.load(open('$tmp_state')); print(len(d.get('cookies',[])))" 2>/dev/null || echo 0)
  if [[ "$cookie_count" -eq 0 ]]; then
    echo "✗ No cookies found in personal Chrome." >&2
    rm -f "$tmp_state"
    return 1
  fi

  # Load into managed Chrome
  AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" state load "$tmp_state" 2>/dev/null \
    && echo "  ✓ Loaded $cookie_count cookies into managed Chrome" >&2 \
    || { echo "  ✗ Failed to load cookies" >&2; rm -f "$tmp_state"; return 1; }

  # Update the backup file too
  cp "$tmp_state" "$AUTH_STATE" 2>/dev/null
  rm -f "$tmp_state"

  # Re-seed localStorage defaults
  _seed

  echo "✓ Reauth complete — grabbed cookies from personal Chrome" >&2
}

# --- Restore: load auth state backup into managed Chrome ---
_restore_auth() {
  if [[ ! -f "$AUTH_STATE" ]]; then
    echo "  No auth backup at $AUTH_STATE — skipping restore" >&2
    return 0
  fi

  # Check if the backup has actual content (not empty cookies)
  local cookie_count
  cookie_count=$(python3 -c "import json; d=json.load(open('$AUTH_STATE')); print(len(d.get('cookies',[])))" 2>/dev/null || echo 0)
  if [[ "$cookie_count" -eq 0 ]]; then
    echo "  Auth backup is empty — skipping restore" >&2
    return 0
  fi

  echo "  Restoring auth from backup ($cookie_count cookies)..." >&2
  AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" state load "$AUTH_STATE" 2>/dev/null \
    && echo "  ✓ Auth restored" >&2 || echo "  ✗ Auth restore failed" >&2
}

# --- Import: headed login + export auth backup ---
_import() {
  if [[ -n "${CCO_SESSION_ID:-}" ]]; then
    echo "✗ Cannot import inside sandbox — run 'ab import' from a terminal." >&2
    return 1
  fi

  echo "▶ Import: starting headed Chrome for manual login..." >&2
  echo "" >&2
  echo "  A Chrome window will open. Log into Google/Clerk on:" >&2
  echo "    1. http://localhost:5173 (local dev)" >&2
  echo "    2. https://slack-feedback-staging.onrender.com (staging)" >&2
  echo "    3. https://terra.clay.com (production)" >&2
  echo "" >&2
  echo "  Press Enter here when done logging in." >&2
  echo "" >&2

  # If Chrome is running headless, kill and restart headed
  local was_running=0
  if _cdp_is_up; then
    was_running=1
    echo "  Stopping headless Chrome first..." >&2
    if [[ -f "$CHROME_PIDFILE" ]]; then
      local p; p="$(cat "$CHROME_PIDFILE")"
      kill "$p" 2>/dev/null; sleep 1
      rm -f "$CHROME_PIDFILE"
    fi
    # Kill daemons too
    pgrep "agent-browser-d" 2>/dev/null | while read -r pid; do kill "$pid" 2>/dev/null; done
    rm -f ~/.agent-browser/default.pid ~/.agent-browser/default.sock
    sleep 1
  fi

  # Launch headed Chrome with same profile
  "$CHROME_BIN" \
    --remote-debugging-port="$CDP_PORT" \
    --user-data-dir="$CHROME_PROFILE" \
    --no-first-run --no-default-browser-check \
    "http://localhost:5173/?renderer=v4" >/dev/null 2>&1 &
  echo "$!" > "$CHROME_PIDFILE"

  local tries=0
  while ! _cdp_is_up && [[ $tries -lt 15 ]]; do sleep 1; tries=$((tries+1)); done
  if ! _cdp_is_up; then
    echo "✗ Chrome failed to start" >&2
    return 1
  fi

  echo "  Chrome is open. Log in now, then press Enter..." >&2
  read -r

  # Export state as backup
  echo "  Exporting auth state..." >&2
  AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" state save "$AUTH_STATE" 2>/dev/null \
    && echo "  ✓ Auth backed up to $AUTH_STATE" >&2 || echo "  ✗ Auth backup failed" >&2

  # Run seed to ensure localStorage defaults
  _seed

  # Restart headless
  echo "  Restarting Chrome headless..." >&2
  local p; p="$(cat "$CHROME_PIDFILE")"
  kill "$p" 2>/dev/null; sleep 1
  pgrep "agent-browser-d" 2>/dev/null | while read -r pid; do kill "$pid" 2>/dev/null; done
  rm -f ~/.agent-browser/default.pid ~/.agent-browser/default.sock "$CHROME_PIDFILE"
  sleep 1

  HEADED=0
  _ensure_chrome

  echo "" >&2
  echo "✓ Import complete. Auth persisted in profile + backed up to terra-auth.json" >&2
  echo "  Managed Chrome is headless again and ready for automation." >&2
}

# --- Heal: kill managed Chrome + daemons, start fresh ---
_heal() {
  echo "▶ Healing..." >&2

  # Kill daemons
  if pgrep -q "agent-browser-d" 2>/dev/null; then
    pgrep "agent-browser-d" | while read -r pid; do
      kill "$pid" 2>/dev/null && echo "  Killed daemon (PID $pid)" >&2 || true
    done
    sleep 1
  fi
  rm -f ~/.agent-browser/default.pid ~/.agent-browser/default.sock

  # Clean session daemon sockets (except dashboard)
  find ~/.agent-browser -name "ab-*.sock" -delete 2>/dev/null || true

  # Kill managed Chrome
  if [[ -f "$CHROME_PIDFILE" ]]; then
    local p; p="$(cat "$CHROME_PIDFILE")"
    kill -0 "$p" 2>/dev/null && { kill "$p" 2>/dev/null; echo "  Killed Chrome (PID $p)" >&2; sleep 1; }
    rm -f "$CHROME_PIDFILE"
  fi

  # Note: heal works inside Seatbelt sandbox — Chrome can relaunch with allowlisted write paths

  local reset_profile=0
  if [[ "${1:-}" == "--reset-profile" ]]; then
    reset_profile=1
    echo "  Resetting profile..." >&2
    if [[ -d "$CHROME_PROFILE" ]]; then
      mv "$CHROME_PROFILE" "${CHROME_PROFILE}-backup-$(date +%s)" 2>/dev/null || true
    fi
  fi

  _ensure_chrome

  # After heal, restore auth backup if profile was reset
  if [[ "$reset_profile" -eq 1 ]]; then
    _restore_auth
    _seed
  fi

  echo "✓ Healed" >&2
}

# --- Status ---
_status() {
  _cdp_is_up && echo "CDP: ✓ port $CDP_PORT" || echo "CDP: ✗ port $CDP_PORT"
  [[ "$HEADED" == "1" ]] && echo "Mode: headed" || echo "Mode: headless"
  [[ -n "${AB_SUBAGENT_SESSION_ID:-}" ]] && echo "Session: ab-$AB_SUBAGENT_SESSION_ID" || echo "Session: (default)"
  local dc; dc=$(pgrep -c "agent-browser-d" 2>/dev/null || echo 0); echo "Daemons: $dc"
  if [[ -f "$CHROME_PIDFILE" ]]; then
    local p; p="$(cat "$CHROME_PIDFILE")"
    kill -0 "$p" 2>/dev/null && echo "Chrome: PID $p" || echo "Chrome: PID $p (dead)"
  fi
  _dashboard_is_up && echo "Dashboard: ✓ http://127.0.0.1:${DASHBOARD_PORT}" || echo "Dashboard: ✗ not running"
  echo "Sessions:"
  AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" session list 2>/dev/null || echo "  (cannot list)"
}

# --- Parse flags from args ---
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --session-name|--session) shift 2 ;;  # stripped — we derive from AB_SUBAGENT_SESSION_ID
    --headed) HEADED=1; shift ;;
    *) ARGS+=("$1"); shift ;;
  esac
done
set -- "${ARGS[@]}"

# --- Session isolation via AB_SUBAGENT_SESSION_ID ---
# Each unique ID gets its own agent-browser daemon (separate .sock, separate active_page).
# No tab switching needed — daemons are independent.
SESSION_ARGS=()
if [[ -n "${AB_SUBAGENT_SESSION_ID:-}" ]]; then
  SESSION_ARGS=(--session "ab-${AB_SUBAGENT_SESSION_ID}")
fi

# --- Warn if no AB_SUBAGENT_SESSION_ID ---
if [[ -z "${AB_SUBAGENT_SESSION_ID:-}" && "${1:-}" != "heal" && "${1:-}" != "status" && "${1:-}" != "ensure" && "${1:-}" != "" ]]; then
  echo "⚠ No AB_SUBAGENT_SESSION_ID set — session isolation disabled. Set AB_SUBAGENT_SESSION_ID for parallel safety." >&2
fi

# --- Main dispatch ---
case "${1:-}" in
  # --- Lifecycle ---
  heal)      _heal "${2:-}" ;;
  status)    _status ;;
  ensure)    _ensure_chrome ;;
  import)    _import ;;
  reauth)    _reauth ;;
  seed)      _seed ;;
  seed-url)
    [[ -z "${2:-}" ]] && { echo "Usage: ab seed-url <url>" >&2; exit 1; }
    _ensure_chrome || exit 1
    echo "▶ Seeding localStorage on $2..." >&2
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" open "$2" 2>/dev/null
    sleep 2
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" eval 'localStorage.setItem("terra:renderer", "v4"); "ok"' 2>/dev/null \
      && echo "  ✓ Set terra:renderer=v4" >&2 || echo "  ✗ Failed (page may need auth first)" >&2
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" open "about:blank" 2>/dev/null
    echo "✓ Seeded $2" >&2
    ;;
  dashboard) _dashboard "${2:-}" ;;

  # --- Navigation (navigate/goto aliased to open) ---
  open|navigate|goto)
    _ensure_chrome
    _open_with_context "${2:-about:blank}"
    ;;

  # --- Recording (auth-safe: records the active tab directly) ---
  # Uses agent-browser's "video" command which records the existing authenticated
  # tab via Page.captureScreenshot at 10fps. Unlike "record", it does NOT create
  # a fresh browser context, so localStorage/sessionStorage auth is preserved.
  record)
    _ensure_chrome
    case "${2:-}" in
      start)
        [[ -z "${3:-}" ]] && { echo "Usage: ab record start <output.webm>" >&2; exit 1; }
        AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" "${SESSION_ARGS[@]}" video start "$3"
        ;;
      stop)
        AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" "${SESSION_ARGS[@]}" video stop
        ;;
      *)
        echo "Usage: ab record <start|stop> [output.webm]" >&2
        exit 1
        ;;
    esac
    ;;

  # --- Allowed agent-browser passthroughs (session-isolated) ---
  snapshot|screenshot|click|fill|type|select|check|press|scroll|\
  find|get|wait|eval|highlight|pdf|diff|set|keyboard|frame)
    _ensure_chrome
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" "${SESSION_ARGS[@]}" "$@"
    rc=$?
    [[ $rc -ne 0 ]] && echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) FAIL($rc) $*" >> "$HOME/.agent-browser/failed-commands.log" 2>/dev/null
    exit $rc
    ;;

  # --- Usage / unknown ---
  "")
    echo "Usage: ab <command> [args...]" >&2
    echo "" >&2
    echo "Navigation:" >&2
    echo "  open <url>          Navigate (creates tab for AB_SUBAGENT_SESSION_ID)" >&2
    echo "" >&2
    echo "Interaction:" >&2
    echo "  snapshot -i         Discover interactive elements (get @refs)" >&2
    echo "  click @ref          Click element" >&2
    echo "  fill @ref \"text\"    Clear and type text" >&2
    echo "  type @ref \"text\"    Type without clearing" >&2
    echo "  select @ref \"opt\"   Select dropdown option" >&2
    echo "  check @ref          Check checkbox" >&2
    echo "  press Enter         Press key" >&2
    echo "  scroll down 500     Scroll page" >&2
    echo "  find text \"X\" click Semantic click by text" >&2
    echo "  keyboard type \"X\"   Type at current focus" >&2
    echo "" >&2
    echo "Inspection:" >&2
    echo "  screenshot          Screenshot to /tmp/agent-browser/" >&2
    echo "  get text @ref       Get element text" >&2
    echo "  get url             Get current URL" >&2
    echo "  eval 'js'           Run JavaScript (localStorage, computed values only)" >&2
    echo "  wait --load networkidle  Wait for page load" >&2
    echo "  diff snapshot       Compare current vs last snapshot" >&2
    echo "  highlight @ref      Highlight element visually" >&2
    echo "" >&2
    echo "Recording:" >&2
    echo "  record start <file> Record video of active tab (auth-safe)" >&2
    echo "  record stop         Stop recording" >&2
    echo "" >&2
    echo "Auth & Lifecycle:" >&2
    echo "  reauth              Grab cookies from personal Chrome" >&2
    echo "  import              Headed login (manual Google/Clerk auth)" >&2
    echo "  seed-url <url>      Seed localStorage on a single origin" >&2
    echo "  heal                Kill everything, restart fresh" >&2
    echo "  status              Show health" >&2
    echo "  dashboard <cmd>     Dashboard management" >&2
    echo "" >&2
    echo "Env: AB_SUBAGENT_SESSION_ID=name (tab isolation), AB_HEADED=1 (headed mode)" >&2
    exit 1
    ;;
  *)
    echo "✗ Unknown command: $1" >&2
    echo "  Run 'ab' with no arguments to see available commands." >&2
    # Log for alias evolution — review with: sort ~/.agent-browser/unknown-commands.log | uniq -c | sort -rn
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) $*" >> "$HOME/.agent-browser/unknown-commands.log" 2>/dev/null
    exit 1
    ;;
esac

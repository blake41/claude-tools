#!/usr/bin/env bash
#
# ab — safe wrapper around agent-browser
#
# Strategy: connect to Chrome via CDP on port 9222. If Chrome isn't running
# with the debug port, launch it ourselves. This is the only reliable approach —
# agent-browser's --headed and --auto-connect are broken/flaky in 0.21.x.
#
# Failure modes this handles:
#   1. No Chrome running → launch Chrome with --remote-debugging-port=9222
#   2. Chrome running without debug port → warn, can't auto-fix (user's Chrome)
#   3. Stale daemon → kill it, reconnect via CDP
#   4. Inside cco sandbox → can't launch Chrome, fail fast with instructions
#   5. NEVER run `pkill chrome` — kills user's personal Chrome
#   6. NEVER run `agent-browser close` — corrupts profile
#
# Usage:
#   ab open <url>              # Open URL (ensures Chrome + CDP connection)
#   ab screenshot <path>       # Take screenshot
#   ab eval "js code"          # Run JavaScript
#   ab <any agent-browser cmd> # Pass through to agent-browser
#   ab ensure                  # Just ensure browser is ready, don't navigate
#   ab heal                    # Force heal (kill daemons, relaunch Chrome, reconnect)
#   ab status                  # Show daemon/session health
#
# Parallel subagent isolation (AB_CONTEXT):
#   When AB_CONTEXT is set, `ab open` creates a dedicated tab and saves its
#   index. All subsequent commands switch to that tab first. This lets N
#   subagents browse simultaneously without stomping on each other's pages.

set -euo pipefail

# --- Config ---
HEALTH_TIMEOUT=5
CDP_PORT=9222
CHROME_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
CHROME_PROFILE="$HOME/.agent-browser/profile"
CHROME_PIDFILE="/tmp/ab-chrome-${CDP_PORT}.pid"

# --- macOS-compatible timeout ---
_timeout() {
  local secs="$1"; shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "$secs" "$@"
  else
    perl -e 'alarm shift; exec @ARGV' "$secs" "$@"
  fi
}

# --- Auto-detect session name ---
_ab_detect_base_session() {
  if [[ -n "${CCO_SESSION_ID:-}" ]]; then
    echo "terra-${CCO_SESSION_ID:0:8}"
    return
  fi
  local cwd="${PWD:-$(pwd)}"
  if [[ "$cwd" == */.claude/worktrees/* ]]; then
    local worktree_name="${cwd##*/.claude/worktrees/}"
    worktree_name="${worktree_name%%/*}"
    echo "terra-${worktree_name}"
    return
  fi
  echo "terra"
}

_ab_browsing_session() {
  local base="$1"
  if [[ -n "${AB_CONTEXT:-}" ]]; then
    echo "${base}-${AB_CONTEXT}"
  else
    echo "${base}"
  fi
}

# --- Tab isolation for parallel subagents ---
_tab_file() {
  echo "/tmp/ab-tab-${AB_CONTEXT:-default}"
}

_claim_tab() {
  local url="${1:-about:blank}"
  if [[ -z "${AB_CONTEXT:-}" ]]; then
    return 0
  fi
  agent-browser tab new "$url" >/dev/null 2>&1
  local idx
  idx=$(agent-browser tab list --json 2>/dev/null | python3 -c "import json,sys; tabs=json.load(sys.stdin)['data']['tabs']; print(next(t['index'] for t in tabs if t['active']))" 2>/dev/null)
  if [[ -n "$idx" ]]; then
    echo "$idx" > "$(_tab_file)"
  fi
}

_switch_to_tab() {
  if [[ -z "${AB_CONTEXT:-}" ]]; then
    return 0
  fi
  local tf
  tf="$(_tab_file)"
  if [[ -f "$tf" ]]; then
    local idx
    idx="$(cat "$tf")"
    agent-browser tab "$idx" >/dev/null 2>&1
  fi
}

# --- Parse session name from args or env ---
BASE_SESSION="${AB_SESSION:-$(_ab_detect_base_session)}"
SESSION=""
PASSTHROUGH_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session-name|--session)
      BASE_SESSION="$2"
      shift 2
      ;;
    *)
      PASSTHROUGH_ARGS+=("$1")
      shift
      ;;
  esac
done

set -- "${PASSTHROUGH_ARGS[@]}"

# --- Blocked commands ---
if [[ "${1:-}" == "close" ]]; then
  echo "✗ BLOCKED: 'close' corrupts the browser profile and breaks daemon state." >&2
  echo "  To reset: ab heal" >&2
  exit 1
fi

# --- Check if CDP port is listening ---
_cdp_is_up() {
  curl -s --max-time 2 "http://127.0.0.1:${CDP_PORT}/json/version" >/dev/null 2>&1
}

# --- Health check: daemon connected and responsive ---
_daemon_is_healthy() {
  _timeout "$HEALTH_TIMEOUT" agent-browser get url >/dev/null 2>&1
}

# --- Kill stale agent-browser daemons ---
_kill_daemons() {
  if pgrep -q "agent-browser-d" 2>/dev/null; then
    pgrep "agent-browser-d" | while read -r pid; do
      kill "$pid" 2>/dev/null && echo "  Killed daemon (PID $pid)" >&2 || true
    done
    sleep 1
  fi
  rm -f ~/.agent-browser/default.pid ~/.agent-browser/default.sock
}

# --- Launch Chrome with CDP debug port ---
_launch_chrome() {
  if _cdp_is_up; then
    echo "✓ Chrome already listening on CDP port $CDP_PORT" >&2
    return 0
  fi

  echo "▶ Launching Chrome with --remote-debugging-port=$CDP_PORT..." >&2

  # Launch Chrome in background with debug port
  "$CHROME_BIN" \
    --remote-debugging-port="$CDP_PORT" \
    --user-data-dir="$CHROME_PROFILE" \
    --no-first-run \
    --no-default-browser-check \
    --disable-background-networking \
    --disable-backgrounding-occluded-windows \
    --disable-component-update \
    --disable-domain-reliability \
    --disable-sync \
    --metrics-recording-only \
    --disable-machine-learning-model-loader \
    --disable-client-side-phishing-detection \
    --safebrowsing-disable-auto-update \
    "about:blank" >/dev/null 2>&1 &

  local chrome_pid=$!
  echo "$chrome_pid" > "$CHROME_PIDFILE"

  # Wait for CDP to come up
  local tries=0
  while ! _cdp_is_up && [[ $tries -lt 15 ]]; do
    sleep 1
    tries=$((tries + 1))
  done

  if _cdp_is_up; then
    echo "✓ Chrome launched (PID $chrome_pid, CDP port $CDP_PORT)" >&2
    return 0
  else
    echo "✗ Chrome launched but CDP port not responding after ${tries}s" >&2
    return 1
  fi
}

# --- Connect agent-browser daemon to Chrome via CDP ---
_connect_cdp() {
  # Kill any stale daemon first — it might be connected to nothing
  _kill_daemons

  echo "▶ Connecting agent-browser to CDP port $CDP_PORT..." >&2

  # Use AGENT_BROWSER_AUTO_CONNECT= to prevent conflict with --cdp
  if AGENT_BROWSER_AUTO_CONNECT= _timeout "$HEALTH_TIMEOUT" agent-browser --cdp "$CDP_PORT" get url >/dev/null 2>&1; then
    echo "✓ Connected to Chrome via CDP" >&2
    return 0
  fi

  echo "✗ Failed to connect agent-browser to CDP port $CDP_PORT" >&2
  return 1
}

# --- Ensure browser is connected and ready ---
ensure_browser() {
  # 1. Already healthy? Done.
  if _daemon_is_healthy; then
    return 0
  fi

  # 2. Inside sandbox — can't launch Chrome, fail fast
  if [[ -n "${CCO_SESSION_ID:-}" ]]; then
    # Try connecting to existing CDP port first (Chrome may be running)
    if _cdp_is_up; then
      _connect_cdp && return 0
    fi
    echo "✗ Browser not responding (session: $BASE_SESSION)." >&2
    echo "  The daemon should have been started before entering the sandbox." >&2
    echo "  Run 'ab heal' from a terminal outside this session, then retry." >&2
    return 1
  fi

  # 3. Outside sandbox — ensure Chrome is running with CDP, then connect
  _launch_chrome || return 1
  _connect_cdp || return 1
}

# --- Heal: kill everything, relaunch, reconnect ---
do_heal() {
  echo "▶ Healing browser setup..." >&2

  # Kill daemons
  _kill_daemons
  echo "✓ Cleaned daemon state" >&2

  # Kill our managed Chrome (NOT user's personal Chrome)
  if [[ -f "$CHROME_PIDFILE" ]]; then
    local chrome_pid
    chrome_pid="$(cat "$CHROME_PIDFILE")"
    if kill -0 "$chrome_pid" 2>/dev/null; then
      kill "$chrome_pid" 2>/dev/null
      echo "  Killed managed Chrome (PID $chrome_pid)" >&2
      sleep 1
    fi
    rm -f "$CHROME_PIDFILE"
  fi

  # If inside sandbox, stop here
  if [[ -n "${CCO_SESSION_ID:-}" ]]; then
    echo "✗ Inside sandbox — run 'ab heal' from an external terminal." >&2
    return 1
  fi

  # Launch fresh Chrome and connect
  _launch_chrome || return 1
  _connect_cdp || return 1
  echo "✓ Healed and reconnected" >&2
}

# --- Status ---
do_status() {
  echo "Session: $BASE_SESSION"

  # Daemon processes
  local daemon_count
  daemon_count=$(pgrep -c "agent-browser-d" 2>/dev/null || echo 0)
  echo "Daemons: $daemon_count running"

  # CDP port
  if _cdp_is_up; then
    echo "CDP port $CDP_PORT: ✓ listening"
  else
    echo "CDP port $CDP_PORT: ✗ not listening"
  fi

  # Managed Chrome PID
  if [[ -f "$CHROME_PIDFILE" ]]; then
    local chrome_pid
    chrome_pid="$(cat "$CHROME_PIDFILE")"
    if kill -0 "$chrome_pid" 2>/dev/null; then
      echo "Managed Chrome: PID $chrome_pid (alive)"
    else
      echo "Managed Chrome: PID $chrome_pid (dead)"
    fi
  else
    echo "Managed Chrome: none tracked"
  fi

  # Health
  if _daemon_is_healthy; then
    local url
    url=$(_timeout "$HEALTH_TIMEOUT" agent-browser get url 2>/dev/null || echo "unknown")
    echo "Health: ✓ connected"
    echo "URL: $url"
  else
    echo "Health: ✗ not responding"
  fi
}

# --- Main dispatch ---
CMD="${1:-}"

case "$CMD" in
  ensure)
    ensure_browser
    ;;
  heal)
    do_heal
    ;;
  status)
    do_status
    ;;
  open)
    ensure_browser
    SESSION="$(_ab_browsing_session "$BASE_SESSION")"
    if [[ -n "${2:-}" ]]; then
      if [[ -n "${AB_CONTEXT:-}" ]]; then
        _claim_tab "$2"
      else
        AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" --session-name "$SESSION" open "$2"
      fi
    fi
    ;;
  "")
    echo "Usage: ab <command> [args...]" >&2
    echo "" >&2
    echo "Commands:" >&2
    echo "  open <url>       Open URL (ensures Chrome + CDP connection)" >&2
    echo "  screenshot <p>   Take screenshot" >&2
    echo "  eval \"js\"        Run JavaScript in page" >&2
    echo "  ensure           Ensure browser is connected (no navigation)" >&2
    echo "  heal             Kill daemons, relaunch Chrome, reconnect" >&2
    echo "  status           Show daemon/session/CDP health" >&2
    echo "  <any cmd>        Pass through to agent-browser" >&2
    exit 1
    ;;
  *)
    _switch_to_tab
    SESSION="$(_ab_browsing_session "$BASE_SESSION")"
    AGENT_BROWSER_AUTO_CONNECT= agent-browser --cdp "$CDP_PORT" --session-name "$SESSION" "$@"
    ;;
esac

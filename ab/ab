#!/usr/bin/env bash
#
# ab — safe wrapper around agent-browser
#
# Encodes everything we've learned about agent-browser failure modes:
#
# 1. NEVER run `agent-browser close` — corrupts profile, breaks daemon
# 2. NEVER run `pkill chrome` — kills user's personal Chrome
# 3. --auto-connect is the preferred mode — attaches to running Chrome
# 4. --headed only as fallback when no Chrome is running
# 5. Health checks need timeouts — `get url` can hang indefinitely
# 6. Multiple daemons can pile up — heal must kill ALL of them
# 7. Daemon must start OUTSIDE cco sandbox
#
# Usage:
#   ab open <url>              # Open URL (auto-connect or launch)
#   ab screenshot <path>       # Take screenshot
#   ab eval "js code"          # Run JavaScript
#   ab <any agent-browser cmd> # Pass through to agent-browser
#   ab ensure                  # Just ensure browser is ready, don't navigate
#   ab heal                    # Force heal (kill daemons, reset profile, restart)
#   ab status                  # Show daemon/session health
#
# All commands use --session terra by default.
# Override with AB_SESSION=<name> or --session-name <name>.
#
# Session isolation:
#   --session-name = cookie/localStorage persistence only (shared tabs)
#   --session      = isolated browser context (separate tabs per session)
#   We use --session so parallel agents each get their own pages.

set -euo pipefail

# --- Config ---
HEALTH_TIMEOUT=5
OPEN_TIMEOUT=15

# --- Auto-detect session name ---
# Priority: AB_SESSION env > auto-detect from context
#
# Two session names:
#   BASE_SESSION = shared per Claude Code instance (for ensure/heal/status)
#   SESSION      = unique per ab invocation (for browsing commands)
#
# This lets parallel subagents each get their own browser context while
# sharing a single daemon. ensure/heal operate on the base session;
# open/screenshot/eval/passthrough get a unique suffix.
_ab_detect_base_session() {
  if [[ -n "${CCO_SESSION_ID:-}" ]]; then
    echo "terra-${CCO_SESSION_ID:0:8}"
    return
  fi

  local cwd="${PWD:-$(pwd)}"

  if [[ "$cwd" == */.claude/worktrees/* ]]; then
    local worktree_name="${cwd##*/.claude/worktrees/}"
    worktree_name="${worktree_name%%/*}"
    echo "terra-${worktree_name}"
    return
  fi

  echo "terra"
}

_ab_browsing_session() {
  # AB_CONTEXT isolates parallel browser subagents. Each subagent must set a
  # unique value before calling ab (e.g., export AB_CONTEXT=qa1).
  # Without it, callers share the base session — fine for single-agent use.
  local base="$1"
  if [[ -n "${AB_CONTEXT:-}" ]]; then
    echo "${base}-${AB_CONTEXT}"
  else
    echo "${base}"
  fi
}

# --- Parse session name from args or env ---
BASE_SESSION="${AB_SESSION:-$(_ab_detect_base_session)}"
SESSION=""  # Set after arg parsing; browsing commands get a unique suffix
PASSTHROUGH_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session-name|--session)
      BASE_SESSION="$2"
      shift 2
      ;;
    *)
      PASSTHROUGH_ARGS+=("$1")
      shift
      ;;
  esac
done

set -- "${PASSTHROUGH_ARGS[@]}"

# --- Blocked commands ---
if [[ "${1:-}" == "close" ]]; then
  echo "✗ BLOCKED: 'close' corrupts the browser profile and breaks daemon state." >&2
  echo "  To reset: ab heal" >&2
  exit 1
fi

# --- Health check (with timeout) ---
is_healthy() {
  timeout "$HEALTH_TIMEOUT" agent-browser --session "$BASE_SESSION" get url >/dev/null 2>&1
}

# --- Detect if running inside cco sandbox ---
_in_sandbox() {
  # cco sets APP_SANDBOX_CONTAINER_ID or we can check for sandbox profile
  [[ -n "${APP_SANDBOX_CONTAINER_ID:-}" ]] || [[ -n "${SANDBOX_ENABLED:-}" ]] || sandbox-exec -p '(version 1)(allow default)' true 2>/dev/null
  # Simpler check: if we can't write to /tmp/ab-sandbox-test, we're sandboxed
  # Actually, just check if cco is our parent process
  [[ "${CCO_SESSION_ID:-}" != "" ]]
}

# --- Ensure browser is connected and ready ---
ensure_browser() {
  # 1. Try existing session
  if is_healthy; then
    return 0
  fi

  # If inside sandbox (CCO_SESSION_ID is set), DON'T try to launch or heal.
  # The daemon should have been started by cco-permissions before entering sandbox.
  # Launching Chrome or healing from inside sandbox is destructive and unreliable.
  if [[ -n "${CCO_SESSION_ID:-}" ]]; then
    echo "✗ Browser not responding (session: $BASE_SESSION)." >&2
    echo "  The daemon should have been started before entering the sandbox." >&2
    echo "  Run 'ab heal' from a terminal outside this session, then retry." >&2
    return 1
  fi

  echo "▶ No healthy session — attempting auto-connect to running Chrome..." >&2

  # 2. Try auto-connect (attaches to already-running Chrome)
  if timeout "$OPEN_TIMEOUT" agent-browser --session "$BASE_SESSION" --auto-connect open "about:blank" >/dev/null 2>&1; then
    if is_healthy; then
      echo "✓ Connected to running Chrome" >&2
      return 0
    fi
  fi

  echo "▶ Auto-connect failed — launching headed Chrome..." >&2

  # 3. Fall back to headed launch (works when Chrome isn't running)
  if timeout "$OPEN_TIMEOUT" agent-browser --session "$BASE_SESSION" --headed open "about:blank" >/dev/null 2>&1; then
    if is_healthy; then
      echo "✓ Launched headed Chrome" >&2
      return 0
    fi
  fi

  # 4. All failed — try heal (only outside sandbox)
  echo "▶ Browser unresponsive — running heal..." >&2
  do_heal || true
  sleep 3  # Give daemon time to stabilize after heal

  # Trust that heal worked — it already tested with open+get url.
  if pgrep -q "agent-browser-d" 2>/dev/null; then
    echo "✓ Healed and reconnected" >&2
    return 0
  fi

  echo "✗ Could not establish browser session." >&2
  echo "  Try: close Chrome, then run 'ab heal' and retry." >&2
  return 1
}

# --- Heal: kill daemons, reset profile, restart ---
do_heal() {
  # Kill ALL daemon processes (not just one)
  if pgrep -q "agent-browser-d" 2>/dev/null; then
    pgrep "agent-browser-d" | while read -r pid; do
      kill "$pid" 2>/dev/null && echo "  Killed daemon (PID $pid)" >&2 || true
    done
    sleep 1
  fi

  # Clean daemon state
  rm -f ~/.agent-browser/default.pid ~/.agent-browser/default.sock

  # Try agent-browser-heal if available (handles profile backup/restore)
  if command -v agent-browser-heal >/dev/null 2>&1; then
    agent-browser-heal --force >&2 || true
  fi
}

# --- Status ---
do_status() {
  echo "Session: $BASE_SESSION"

  # Daemon processes
  local daemon_count
  daemon_count=$(pgrep -c "agent-browser-d" 2>/dev/null || echo 0)
  echo "Daemons: $daemon_count running"

  # PID file
  if [[ -f ~/.agent-browser/default.pid ]]; then
    echo "PID file: $(cat ~/.agent-browser/default.pid)"
  else
    echo "PID file: none"
  fi

  # Socket
  if [[ -S ~/.agent-browser/default.sock ]]; then
    echo "Socket: exists"
  else
    echo "Socket: missing"
  fi

  # Health
  if is_healthy; then
    local url
    url=$(timeout "$HEALTH_TIMEOUT" agent-browser --session "$BASE_SESSION" get url 2>/dev/null || echo "unknown")
    echo "Health: ✓ connected"
    echo "URL: $url"
  else
    echo "Health: ✗ not responding"
  fi

  # Session file
  local session_file=~/.agent-browser/sessions/${BASE_SESSION}-default.json
  if [[ -f "$session_file" ]]; then
    echo "Session file: $session_file ($(wc -c < "$session_file" | tr -d ' ') bytes)"
  else
    echo "Session file: none"
  fi
}

# --- Main dispatch ---
CMD="${1:-}"

case "$CMD" in
  ensure)
    ensure_browser
    ;;
  heal)
    do_heal
    ;;
  status)
    do_status
    ;;
  open)
    # Ensure daemon is ready, then navigate in an isolated context
    ensure_browser
    SESSION="$(_ab_browsing_session "$BASE_SESSION")"
    if [[ -n "${2:-}" ]]; then
      agent-browser --session "$SESSION" open "$2"
    fi
    ;;
  "")
    echo "Usage: ab <command> [args...]" >&2
    echo "" >&2
    echo "Commands:" >&2
    echo "  open <url>       Open URL (ensures browser is ready first)" >&2
    echo "  screenshot <p>   Take screenshot" >&2
    echo "  eval \"js\"        Run JavaScript in page" >&2
    echo "  ensure           Ensure browser is connected (no navigation)" >&2
    echo "  heal             Kill daemons, reset profile, restart" >&2
    echo "  status           Show daemon/session health" >&2
    echo "  <any cmd>        Pass through to agent-browser" >&2
    exit 1
    ;;
  *)
    # All other commands: pass through in an isolated context
    SESSION="$(_ab_browsing_session "$BASE_SESSION")"
    agent-browser --session "$SESSION" "$@"
    ;;
esac

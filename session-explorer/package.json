{
  "name": "session-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "ingest": "bun run server/ingest.ts",
    "ingest:all": "bun run server/ingest.ts --all",
    "ingest:force": "bun run server/ingest.ts --force",
    "start": "bun server/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@tanstack/react-router": "^1.168.3",
    "cors": "^2.8.5",
    "esbuild": "^0.27.4",
    "express": "^4.21.0",
    "nuqs": "^2.8.9",
    "p-queue": "^9.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0",
    "vite": "^7.3.1"
  }
}

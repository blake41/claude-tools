#!/bin/bash
set -euo pipefail

REAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$REAL_SCRIPT")"

source "$SCRIPT_DIR/../cli-envelope.sh"

TOOL_NAME="skill-gen"
SKILLS_DIR="${HOME}/.claude/skills"
MARKER="<!-- generated by skill-gen -->"

# --- Helpers ---

# capture_with_timeout <seconds> <outfile> <command...>
# Runs command, writes stdout to outfile, kills after timeout.
# Returns 0 on success, 1 on timeout or failure.
capture_with_timeout() {
  local secs="$1"
  local outfile="$2"
  shift 2
  "$@" > "$outfile" 2>/dev/null &
  local pid=$!
  (
    sleep "$secs"
    kill "$pid" 2>/dev/null
  ) &
  local watcher=$!
  if wait "$pid" 2>/dev/null; then
    kill "$watcher" 2>/dev/null
    wait "$watcher" 2>/dev/null
    return 0
  else
    kill "$watcher" 2>/dev/null
    wait "$watcher" 2>/dev/null
    return 1
  fi
}

# title_case "api-probe" => "API Probe"
title_case() {
  local acronyms="api cli ctl ui sql ssh http url dns db mcp sf"
  echo "$1" | tr '-' ' ' | awk -v ac="$acronyms" '
    BEGIN { split(ac, a, " "); for(i in a) acronym[a[i]]=1 }
    { for(i=1;i<=NF;i++) {
        if(tolower($i) in acronym) $i=toupper($i)
        else $i=toupper(substr($i,1,1)) tolower(substr($i,2))
      }
      print
    }'
}

# infer_triggers <tool-name> <description> [custom-csv]
# Prints trigger words, one per line.
infer_triggers() {
  local tool_name="$1"
  local description="$2"
  local custom="${3:-}"

  local stop_words="for the a an and or of to with in on is are was were be been being has have had do does did will would shall should may might can could"
  local triggers=()

  # 1. Tool name itself
  triggers+=("$tool_name")

  # 2. Significant words from description
  for word in $description; do
    word=$(echo "$word" | tr '[:upper:]' '[:lower:]' | tr -d '.,;:()')
    if [[ ${#word} -gt 2 ]] && ! echo " $stop_words " | grep -q " $word "; then
      triggers+=("$word")
    fi
  done

  # 3. Custom triggers
  if [[ -n "$custom" ]]; then
    IFS=',' read -ra parts <<< "$custom"
    for t in "${parts[@]}"; do
      t=$(echo "$t" | xargs) # trim whitespace
      [[ -n "$t" ]] && triggers+=("$t")
    done
  fi

  # Deduplicate, limit to 8
  printf '%s\n' "${triggers[@]}" | awk '!seen[$0]++' | head -8
}

# detect_config_path <tool-name>
# Greps the tool script for config patterns. Prints path or empty.
detect_config_path() {
  local tool_name="$1"
  local tool_path
  tool_path=$(command -v "$tool_name" 2>/dev/null) || return 0

  # Resolve symlink to actual script
  local real_path
  real_path=$(readlink "$tool_path" 2>/dev/null || echo "$tool_path")

  # Check for ~/.config/<service> patterns
  local service
  service=$(echo "$tool_name" | sed -E 's/-(cli|api|ctl)$//')

  if [[ -d "${HOME}/.config/${service}" ]]; then
    echo "~/.config/${service}/"
    return
  fi

  # Grep the script for config references
  local config_ref
  config_ref=$(grep -oE '\$HOME/\.config/[a-zA-Z0-9_-]+|~/\.config/[a-zA-Z0-9_-]+' "$real_path" 2>/dev/null | head -1 || true)
  if [[ -n "$config_ref" ]]; then
    echo "${config_ref}/"
    return
  fi

  # Check for .env references
  if grep -q '\.env' "$real_path" 2>/dev/null; then
    echo ".env in project root"
    return
  fi
}

# --- Subcommands ---

cmd_list() {
  local tools=()
  local bin_dir="${HOME}/.local/bin"

  if [[ ! -d "$bin_dir" ]]; then
    json_error "$TOOL_NAME list" "Directory $bin_dir not found" "NOT_FOUND" \
      "Tools should be symlinked to ~/.local/bin/"
  fi

  for tool_path in "$bin_dir"/*; do
    [[ -x "$tool_path" ]] || continue
    local name
    name=$(basename "$tool_path")

    # Skip non-tool binaries and self
    [[ "$name" == "skill-gen" ]] && continue

    # Run with no args, capture output, 3s timeout
    local tmpout
    tmpout=$(mktemp)
    capture_with_timeout 3 "$tmpout" "$tool_path" || { rm -f "$tmpout"; continue; }
    local output
    output=$(cat "$tmpout")
    rm -f "$tmpout"

    # Check if it's a valid cmd_tree response
    if echo "$output" | jq -e '.ok == true and .result.commands' &>/dev/null; then
      local description
      description=$(echo "$output" | jq -r '.result.description // "No description"')
      local cmd_count
      cmd_count=$(echo "$output" | jq '.result.commands | length')
      local has_skill=false
      [[ -f "${SKILLS_DIR}/${name}/SKILL.md" ]] && has_skill=true

      tools+=("$(jq -n \
        --arg name "$name" \
        --arg description "$description" \
        --argjson commands "$cmd_count" \
        --argjson has_skill "$has_skill" \
        '{name: $name, description: $description, commands: $commands, has_skill: $has_skill}')")
    fi
  done

  local tools_json="[]"
  if [[ ${#tools[@]} -gt 0 ]]; then
    tools_json=$(printf '%s\n' "${tools[@]}" | jq -s .)
  fi

  local first_without_skill
  first_without_skill=$(echo "$tools_json" | jq -r '[.[] | select(.has_skill == false)][0].name // empty')

  local na_items=()
  if [[ -n "$first_without_skill" ]]; then
    na_items+=("$(next_action "skill-gen ${first_without_skill} --preview" "Preview skill for ${first_without_skill}")")
  fi

  local na
  if [[ ${#na_items[@]} -gt 0 ]]; then
    na=$(next_actions "${na_items[@]}")
  else
    na=$(next_actions)
  fi

  json_ok "$TOOL_NAME list" "$tools_json" "$na"
}

cmd_generate() {
  local tool_name=""
  local preview=false
  local custom_triggers=""
  local force=false
  local output_path=""

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --preview)  preview=true; shift ;;
      --force)    force=true; shift ;;
      --triggers) custom_triggers="$2"; shift 2 ;;
      --output)   output_path="$2"; shift 2 ;;
      --*)        json_error "$TOOL_NAME" "Unknown flag: $1" "INVALID_ARG" \
                    "Usage: skill-gen <tool-name> [--preview] [--triggers \"word1,word2\"]" ;;
      *)
        if [[ -z "$tool_name" ]]; then
          tool_name="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$tool_name" ]] && json_error "$TOOL_NAME" "Tool name required" "MISSING_ARG" \
    "Usage: skill-gen <tool-name> [--preview] [--triggers \"word1,word2\"]"

  # Locate tool
  if ! command -v "$tool_name" &>/dev/null; then
    json_error "$TOOL_NAME" "Tool '$tool_name' not found" "NOT_FOUND" \
      "Check it's installed in ~/.local/bin/ or on PATH"
  fi

  # Get cmd_tree output
  local tmpout
  tmpout=$(mktemp)
  capture_with_timeout 5 "$tmpout" "$tool_name" || {
    rm -f "$tmpout"
    json_error "$TOOL_NAME" "Tool '$tool_name' failed or timed out" "INVALID_FORMAT" \
      "Run '$tool_name' with no args to check its output"
  }
  local output
  output=$(cat "$tmpout")
  rm -f "$tmpout"

  # Validate cmd_tree format
  if ! echo "$output" | jq -e '.ok == true and .result.commands and .result.description' &>/dev/null; then
    json_error "$TOOL_NAME" "Tool '$tool_name' does not produce cmd_tree JSON" "INVALID_FORMAT" \
      "Run '$tool_name' with no args — expected JSON with .ok, .result.description, .result.commands"
  fi

  # Extract data
  local description
  description=$(echo "$output" | jq -r '.result.description')
  local commands_json
  commands_json=$(echo "$output" | jq '.result.commands')

  # Infer triggers
  local triggers_array=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && triggers_array+=("$line")
  done < <(infer_triggers "$tool_name" "$description" "$custom_triggers")

  # Detect config
  local config_path
  config_path=$(detect_config_path "$tool_name")

  # Check existing skill
  local skill_path="${output_path:-${SKILLS_DIR}/${tool_name}/SKILL.md}"
  local overwritten=false

  if [[ "$preview" == "false" && -f "$skill_path" ]]; then
    if grep -q "$MARKER" "$skill_path"; then
      overwritten=true
    elif [[ "$force" != "true" ]]; then
      json_error "$TOOL_NAME" "Skill at $skill_path exists and appears hand-written (no skill-gen marker)" \
        "SKILL_EXISTS_HANDWRITTEN" "Use --force to overwrite, or --preview to see what would be generated"
    else
      overwritten=true
    fi
  fi

  # Build SKILL.md content
  local title
  title=$(title_case "$tool_name")

  local triggers_yaml=""
  for t in "${triggers_array[@]}"; do
    triggers_yaml+="  - ${t}"$'\n'
  done

  local commands_block=""
  commands_block=$(echo "$commands_json" | jq -r '.[] | .usage + "    # " + .description')

  local config_line=""
  if [[ -n "$config_path" ]]; then
    config_line=$'\n'"Config: \`${config_path}\`"
  fi

  local content
  content="---
description: ${description}
triggers:
${triggers_yaml}tools: [Bash]
---

# ${title}

${description}.

## Commands

\`\`\`bash
${commands_block}
\`\`\`
${config_line}

${MARKER}"

  if [[ "$preview" == "true" ]]; then
    local result
    result=$(jq -n \
      --arg tool "$tool_name" \
      --argjson preview true \
      --arg content "$content" \
      --argjson triggers "$(printf '%s\n' "${triggers_array[@]}" | jq -R . | jq -s .)" \
      --arg config_path "${config_path:-}" \
      '{tool: $tool, preview: $preview, content: $content,
        triggers: $triggers, config_path: $config_path}')

    local na
    na=$(next_actions \
      "$(next_action "skill-gen ${tool_name}" "Write the skill file")")
    json_ok "$TOOL_NAME $tool_name" "$result" "$na"
  else
    # Write the file
    local skill_dir
    skill_dir=$(dirname "$skill_path")
    mkdir -p "$skill_dir"
    echo "$content" > "$skill_path"

    local result
    result=$(jq -n \
      --arg tool "$tool_name" \
      --arg written_to "$skill_path" \
      --argjson triggers "$(printf '%s\n' "${triggers_array[@]}" | jq -R . | jq -s .)" \
      --arg config_path "${config_path:-}" \
      --argjson overwritten "$overwritten" \
      '{tool: $tool, written_to: $written_to, triggers: $triggers,
        config_path: $config_path, overwritten: $overwritten}')

    local na
    na=$(next_actions \
      "$(next_action "skill-gen ${tool_name} --preview" "Preview the generated skill")" \
      "$(next_action "skill-gen list" "List all tools with cmd_tree output")")
    json_ok "$TOOL_NAME $tool_name" "$result" "$na"
  fi
}

# --- Dispatch ---

case "${1:-}" in
  list)
    cmd_list
    ;;
  --help|-h|help)
    cmd_tree "$TOOL_NAME" "Generate SKILL.md from a tool's cmd_tree output" "$(jq -n '[
      {name: "<tool-name>", description: "Generate skill for a specific tool", usage: "skill-gen <tool-name> [--preview] [--triggers \"word1,word2\"] [--force]"},
      {name: "list", description: "List tools with cmd_tree output", usage: "skill-gen list"}
    ]')"
    ;;
  "")
    cmd_tree "$TOOL_NAME" "Generate SKILL.md from a tool's cmd_tree output" "$(jq -n '[
      {name: "<tool-name>", description: "Generate skill for a specific tool", usage: "skill-gen <tool-name> [--preview] [--triggers \"word1,word2\"] [--force]"},
      {name: "list", description: "List tools with cmd_tree output", usage: "skill-gen list"}
    ]')"
    ;;
  --*)
    json_error "$TOOL_NAME" "Unknown flag: $1" "INVALID_ARG" \
      "Usage: skill-gen <tool-name> [--preview] [--triggers \"word1,word2\"]"
    ;;
  *)
    cmd_generate "$@"
    ;;
esac

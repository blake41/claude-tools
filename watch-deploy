#!/usr/bin/env bash
# Watch for a Render deploy to finish and send a macOS notification.
# Usage: watch-deploy <repo> <environment> <branch> <commit-sha> <commit-message>
#
# Polls both GitHub Actions and Render deploys. If CI fails, notifies
# immediately instead of waiting for a Render deploy that will never come.

set -uo pipefail
# NOTE: no `set -e` — this is a background polling script that must survive
# transient failures (network blips, API timeouts, jq parse errors).

REPO="${1:-}"
ENV="${2:-}"
BRANCH="${3:-}"
COMMIT_SHA="${4:-}"
COMMIT_MSG="${5:-}"

if [[ -z "$REPO" || -z "$ENV" ]]; then
  echo "Usage: watch-deploy <repo> <environment> <branch> <commit-sha> <commit-message>" >&2
  exit 1
fi

# Map repo+environment to Render service ID and GH workflow name
case "$REPO/$ENV" in
  clay-run/Terra/staging)
    SERVICE_ID="srv-d2f17tjipnbc73ailtb0"
    GH_WORKFLOW="Docker Build and Push"
    ;;
  clay-run/Terra/production)
    SERVICE_ID="srv-d1686m6mcj7s73bdqod0"
    GH_WORKFLOW="Docker Build and Push"
    ;;
  clay-run/keystone/staging)
    SERVICE_ID="srv-d6ir1ahdrdic73eko3v0"
    GH_WORKFLOW="Build and Push Docker Image"
    ;;
  clay-run/keystone/production)
    SERVICE_ID="srv-d5ij7eadbo4c73el9s80"
    GH_WORKFLOW="Build and Push Docker Image"
    ;;
  *)
    echo "Unknown repo/env: $REPO/$ENV" >&2; exit 1
    ;;
esac

GH_REPO="$REPO"
SHORT_SHA="${COMMIT_SHA:0:7}"
POLL_INTERVAL=15
MAX_WAIT=600  # 10 minutes
WAITED=0

# Logging
LOGFILE="$HOME/Library/Logs/watch-deploy.log"
log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOGFILE"; }

# Kill any previous watcher for the same repo+env
PIDFILE="/tmp/watch-deploy-${REPO//\//-}-${ENV}.pid"
if [[ -f "$PIDFILE" ]]; then
  OLD_PID=$(cat "$PIDFILE" 2>/dev/null)
  if [[ -n "$OLD_PID" ]] && kill -0 "$OLD_PID" 2>/dev/null; then
    log "KILLING_STALE pid=$OLD_PID"
    kill "$OLD_PID" 2>/dev/null || true
  fi
fi
echo $$ > "$PIDFILE"
trap 'rm -f "$PIDFILE"' EXIT

log "START repo=$GH_REPO env=$ENV branch=$BRANCH sha=$SHORT_SHA msg=\"$COMMIT_MSG\" service=$SERVICE_ID"

# Capture the current latest deploy ID so we can detect a new one
INITIAL_DEPLOY_ID=$(render-services deploys "$SERVICE_ID" 2>/dev/null \
  | jq -r '.result[0].id // empty' 2>/dev/null) || INITIAL_DEPLOY_ID=""

log "INITIAL_DEPLOY_ID=$INITIAL_DEPLOY_ID"

RENDER_URL="https://dashboard.render.com/web/${SERVICE_ID}/deploys"

notify() {
  local title="$1" body="$2" sound="${3:-default}" url="${4:-$RENDER_URL}"
  log "NOTIFY title=\"$title\" body=\"$body\""
  terminal-notifier -title "$title" -subtitle "$ENV" -message "$body" -sound "$sound" -open "$url" 2>/dev/null || true
}

# Check if the GH Actions CI run has failed for this branch
check_ci() {
  if [[ -z "$BRANCH" ]]; then return 0; fi
  local result
  if ! result=$(gh run list \
    --repo "$GH_REPO" \
    --branch "$BRANCH" \
    --workflow "$GH_WORKFLOW" \
    --json conclusion,databaseId,headSha \
    --limit 5 2>&1); then
    log "GH_API_ERROR: $result"
    return 0  # API error — keep polling, don't bail
  fi

  # No runs found yet — CI hasn't started
  if [[ -z "$result" || "$result" == "[]" ]]; then return 0; fi

  # Find the run matching our commit SHA — ignore runs for other commits
  local matched
  matched=$(echo "$result" | jq -r "[.[] | select(.headSha == \"$COMMIT_SHA\")] | .[0] // empty")
  if [[ -z "$matched" || "$matched" == "null" ]]; then return 0; fi

  local conclusion run_id
  conclusion=$(echo "$matched" | jq -r '.conclusion // empty')
  run_id=$(echo "$matched" | jq -r '.databaseId // empty')

  case "$conclusion" in
    failure)
      log "CI_FAILED workflow=\"$GH_WORKFLOW\" run=$run_id after ${WAITED}s"
      notify "CI Failed" "Docker build failed — ${SHORT_SHA} ${COMMIT_MSG}" "Basso" "https://github.com/${GH_REPO}/actions/runs/${run_id}"
      exit 1
      ;;
    cancelled)
      log "CI_CANCELLED workflow=\"$GH_WORKFLOW\" run=$run_id after ${WAITED}s"
      notify "CI Cancelled" "Build cancelled — ${SHORT_SHA} ${COMMIT_MSG}" "Basso" "https://github.com/${GH_REPO}/actions/runs/${run_id}"
      exit 1
      ;;
  esac
  return 0
}

# Wait for a new deploy to appear (the one triggered by our push)
while true; do
  # Check CI status — bail early if build failed
  check_ci

  DEPLOY_JSON=$(render-services deploys "$SERVICE_ID" 2>/dev/null) || true
  LATEST_ID=$(echo "$DEPLOY_JSON" | jq -r '.result[0].id // empty' 2>/dev/null) || true

  # Only break if we got a real deploy ID that differs from the initial one.
  # Empty LATEST_ID means the API failed — keep polling, don't false-positive.
  if [[ -n "$LATEST_ID" && "$LATEST_ID" != "$INITIAL_DEPLOY_ID" ]]; then
    log "NEW_DEPLOY id=$LATEST_ID after ${WAITED}s"
    break
  fi

  WAITED=$((WAITED + POLL_INTERVAL))
  if (( WAITED >= MAX_WAIT )); then
    log "TIMEOUT no new deploy after ${MAX_WAIT}s, latest_id=$LATEST_ID"
    notify "Deploy Timeout" "No new deploy detected after ${MAX_WAIT}s" "Basso"
    exit 1
  fi

  sleep "$POLL_INTERVAL"
done

# Now poll until the new deploy reaches a terminal state
while true; do
  DEPLOY_JSON=$(render-services deploys "$SERVICE_ID" 2>/dev/null) || true
  STATUS=$(echo "$DEPLOY_JSON" | jq -r '.result[0].status // "unknown"' 2>/dev/null) || STATUS="unknown"

  case "$STATUS" in
    live)
      log "SUCCESS deploy=$LATEST_ID after ${WAITED}s"
      notify "Deploy Succeeded" "${SHORT_SHA} ${COMMIT_MSG}" "Glass"
      exit 0
      ;;
    build_failed|update_failed|canceled|pre_deploy_failed)
      log "FAILED status=$STATUS deploy=$LATEST_ID after ${WAITED}s"
      notify "Deploy Failed" "$STATUS — ${SHORT_SHA} ${COMMIT_MSG}" "Basso"
      exit 1
      ;;
    deactivated)
      log "SUPERSEDED deploy=$LATEST_ID after ${WAITED}s"
      notify "Deploy Superseded" "Replaced — ${SHORT_SHA}" "Purr"
      exit 0
      ;;
    created|build_in_progress|update_in_progress|pre_deploy_in_progress)
      # Known in-progress states — keep polling
      ;;
    *)
      log "UNKNOWN_STATUS status=$STATUS deploy=$LATEST_ID after ${WAITED}s"
      ;;
  esac

  WAITED=$((WAITED + POLL_INTERVAL))
  if (( WAITED >= MAX_WAIT )); then
    log "TIMEOUT status=$STATUS deploy=$LATEST_ID after ${MAX_WAIT}s"
    notify "Deploy Timeout" "Still $STATUS after ${MAX_WAIT}s — ${SHORT_SHA}" "Basso"
    exit 1
  fi

  sleep "$POLL_INTERVAL"
done

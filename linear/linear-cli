#!/usr/bin/env bash
# linear-cli - Linear issue management for AI agents
# Linear API is GraphQL-based, this provides convenient commands

set -euo pipefail

REAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$REAL_SCRIPT")"
source "$SCRIPT_DIR/../cli-envelope.sh"

TOOL_NAME="linear-cli"
CONFIG_DIR="${HOME}/.config/linear"
API_URL="https://api.linear.app/graphql"

# Get API key from config or environment
get_api_key() {
  if [[ -n "${LINEAR_API_KEY:-}" ]]; then
    echo "$LINEAR_API_KEY"
  elif [[ -f "$CONFIG_DIR/api-key" ]]; then
    cat "$CONFIG_DIR/api-key"
  else
    json_error "$TOOL_NAME" "No Linear API key found" "AUTH_MISSING" "Set LINEAR_API_KEY or create ~/.config/linear/api-key. Get your key from: Linear Settings > Security & access > API keys"
  fi
}

# Execute GraphQL query
graphql() {
  local query="$1"
  local api_key
  api_key=$(get_api_key)

  local result
  result=$(curl -s -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: $api_key" \
    --data "{\"query\": \"$query\"}" \
    "$API_URL")

  # Check for GraphQL errors
  if echo "$result" | jq -e '.errors' > /dev/null 2>&1; then
    local msg
    msg=$(echo "$result" | jq -r '.errors[0].message // "Unknown GraphQL error"')
    json_error "$TOOL_NAME" "$msg" "API_ERROR" "Check your query syntax and API key"
  fi

  echo "$result"
}

# Commands
cmd_me() {
  local result
  result=$(graphql "{ viewer { id name email admin } }" | jq '.data.viewer')
  local na
  na=$(next_actions \
      "$(next_action "linear-cli issues --mine" "List your assigned issues")" \
      "$(next_action "linear-cli teams" "List all teams")")
  json_ok "$TOOL_NAME me" "$result" "$na"
}

cmd_teams() {
  local result
  result=$(graphql "{ teams { nodes { id name key description } } }" | jq '.data.teams.nodes')
  local na
  na=$(next_actions \
      "$(next_action "linear-cli issues --mine" "List your assigned issues")" \
      "$(next_action "linear-cli projects" "List all projects")")
  json_ok "$TOOL_NAME teams" "$result" "$na"
}

cmd_projects() {
  local result
  result=$(graphql "{ projects(first: 50) { nodes { id name description state { name } lead { name } targetDate } } }" | jq '.data.projects.nodes')
  local na
  na=$(next_actions \
      "$(next_action "linear-cli issues --project \"<project-name>\"" "List issues in a project")")
  json_ok "$TOOL_NAME projects" "$result" "$na"
}

# Download Linear upload images from description, resize for AI vision, cache locally.
# Sets $PROCESSED_DESCRIPTION (URLs replaced with local paths) and $IMAGES_JSON (array).
process_description_images() {
  local description="$1"
  local image_dir="/tmp/linear-images"
  mkdir -p "$image_dir"

  local api_key
  api_key=$(get_api_key)

  local images_json="[]"
  local processed_desc="$description"

  # Extract all markdown image URLs pointing to Linear uploads
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local alt url
    alt=$(echo "$line" | sed -n 's/.*!\[\([^]]*\)\].*/\1/p')
    url=$(echo "$line" | sed -n 's/.*!(\([^)]*\)).*/\1/p')
    [[ -z "$url" ]] && url=$(echo "$line" | sed -n 's/.*(\(https:\/\/uploads\.linear\.app\/[^)]*\)).*/\1/p')
    [[ -z "$url" ]] && continue

    # Deterministic filename from URL hash
    local hash
    hash=$(echo -n "$url" | md5 -q 2>/dev/null || echo -n "$url" | md5sum | cut -d' ' -f1)
    local cached_path="$image_dir/${hash}.png"

    # Download and resize if not cached
    if [[ ! -f "$cached_path" ]]; then
      local tmp_path="$image_dir/${hash}_raw"
      local http_code
      http_code=$(curl -s -w '%{http_code}' -H "Authorization: $api_key" -o "$tmp_path" "$url")

      if [[ "$http_code" == "200" && -f "$tmp_path" && -s "$tmp_path" ]]; then
        # Resize to max 1200px on longest edge (macOS sips)
        if command -v sips &>/dev/null; then
          sips -Z 1200 "$tmp_path" --out "$cached_path" &>/dev/null
        else
          cp "$tmp_path" "$cached_path"
        fi
        rm -f "$tmp_path"
      else
        rm -f "$tmp_path"
        continue
      fi
    fi

    # Add to images array
    images_json=$(echo "$images_json" | jq --arg path "$cached_path" --arg alt "$alt" --arg url "$url" \
      '. + [{"path": $path, "alt": $alt, "original_url": $url}]')

    # Replace URL in description with local path
    local escaped_url
    escaped_url=$(printf '%s\n' "$url" | sed 's/[[\.*^$()+?{|]/\\&/g')
    processed_desc=$(echo "$processed_desc" | sed "s|$escaped_url|$cached_path|g")
  done < <(echo "$description" | grep -oE '!\[[^]]*\]\(https://uploads\.linear\.app/[^)]+\)')

  PROCESSED_DESCRIPTION="$processed_desc"
  IMAGES_JSON="$images_json"
}

cmd_issue() {
  local issue_id="$1"
  # Parse identifier like "GTM-3424" into team key and number
  local team_key="${issue_id%-*}"
  local number="${issue_id##*-}"

  if [[ ! "$number" =~ ^[0-9]+$ ]]; then
    json_error "$TOOL_NAME issue" "Invalid issue ID format. Expected: TEAM-123 (e.g., GTM-3424)" "INVALID_ARG" "Use format TEAM-NUMBER, e.g. GTM-123"
  fi

  local result
  result=$(graphql "{ issues(filter: { number: { eq: $number }, team: { key: { eq: \\\"$team_key\\\" } } }, first: 1) { nodes { id identifier title description state { name } priority assignee { name } project { name } labels { nodes { name } } attachments { nodes { id title url metadata sourceType } } createdAt updatedAt } } }" | jq '.data.issues.nodes[0] // empty')

  if [[ -z "$result" || "$result" == "null" ]]; then
    json_error "$TOOL_NAME issue" "Issue '$issue_id' not found" "NOT_FOUND" "Check the issue identifier"
  fi

  # Process inline images from description
  local description
  description=$(echo "$result" | jq -r '.description // ""')

  if echo "$description" | grep -q 'https://uploads\.linear\.app/'; then
    process_description_images "$description"
    # Update result with processed description and images array
    result=$(echo "$result" | jq --arg desc "$PROCESSED_DESCRIPTION" --argjson imgs "$IMAGES_JSON" \
      '.description = $desc | .images = $imgs')
  fi

  local na
  na=$(next_actions \
      "$(next_action "linear-cli comment $issue_id \"<comment>\"" "Add a comment to this issue")" \
      "$(next_action "linear-cli issues --mine" "List your assigned issues")")
  json_ok "$TOOL_NAME issue" "$result" "$na"
}

cmd_comment() {
  local issue_id="$1"
  local body="$2"

  # Parse identifier like "GTM-3424" into team key and number
  local team_key="${issue_id%-*}"
  local number="${issue_id##*-}"

  if [[ ! "$number" =~ ^[0-9]+$ ]]; then
    json_error "$TOOL_NAME comment" "Invalid issue ID format. Expected: TEAM-123 (e.g., GTM-3424)" "INVALID_ARG" "Use format TEAM-NUMBER, e.g. GTM-123"
  fi

  # Get the issue's internal UUID
  local issue_result
  issue_result=$(graphql "{ issues(filter: { number: { eq: $number }, team: { key: { eq: \\\"$team_key\\\" } } }, first: 1) { nodes { id } } }")
  local issue_uuid
  issue_uuid=$(echo "$issue_result" | jq -r '.data.issues.nodes[0].id // empty')

  if [[ -z "$issue_uuid" ]]; then
    json_error "$TOOL_NAME comment" "Issue '$issue_id' not found" "NOT_FOUND" "Check the issue identifier"
  fi

  # Escape quotes and newlines in body
  body=$(echo "$body" | sed 's/"/\\\\"/g' | tr '\n' ' ')

  local result
  result=$(graphql "mutation { commentCreate(input: { issueId: \\\"$issue_uuid\\\", body: \\\"$body\\\" }) { success comment { id body createdAt user { name } } } }")

  local success
  success=$(echo "$result" | jq -r '.data.commentCreate.success')

  if [[ "$success" != "true" ]]; then
    json_error "$TOOL_NAME comment" "Failed to add comment" "API_ERROR" "Check the issue ID and comment body"
  fi

  local comment_data
  comment_data=$(echo "$result" | jq '.data.commentCreate.comment')

  local na
  na=$(next_actions \
      "$(next_action "linear-cli issue $issue_id" "View issue details")" \
      "$(next_action "linear-cli issues --mine" "List your assigned issues")")
  json_ok "$TOOL_NAME comment" "$comment_data" "$na"
}

# Resolve issue identifier (e.g. GTM-3768) to internal UUID
resolve_issue_uuid() {
  local issue_id="$1"
  local team_key="${issue_id%-*}"
  local number="${issue_id##*-}"

  if [[ ! "$number" =~ ^[0-9]+$ ]]; then
    json_error "$TOOL_NAME" "Invalid issue ID format. Expected: TEAM-123 (e.g., GTM-3424)" "INVALID_ARG" "Use format TEAM-NUMBER, e.g. GTM-123"
  fi

  local issue_result
  issue_result=$(graphql "{ issues(filter: { number: { eq: $number }, team: { key: { eq: \\\"$team_key\\\" } } }, first: 1) { nodes { id } } }")
  local uuid
  uuid=$(echo "$issue_result" | jq -r '.data.issues.nodes[0].id // empty')

  if [[ -z "$uuid" ]]; then
    json_error "$TOOL_NAME" "Issue '$issue_id' not found" "NOT_FOUND" "Check the issue identifier"
  fi
  echo "$uuid"
}

cmd_cancel() {
  local issue_id="$1"
  # cancel is just a shortcut for update --state Canceled
  cmd_update "$issue_id" --state "Canceled"
}

# Execute a GraphQL mutation with proper variable escaping (like cmd_create)
graphql_mutation() {
  local query="$1"
  local variables="$2"
  local api_key
  api_key=$(get_api_key)

  local payload
  payload=$(jq -n --arg q "$query" --argjson vars "$variables" '{query: $q, variables: $vars}')

  local result
  result=$(curl -s -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: $api_key" \
    --data "$payload" \
    "$API_URL")

  if echo "$result" | jq -e '.errors' > /dev/null 2>&1; then
    local msg
    msg=$(echo "$result" | jq -r '.errors[0].message // "Unknown GraphQL error"')
    json_error "$TOOL_NAME" "$msg" "API_ERROR" "Check your query and API key"
  fi

  echo "$result"
}

# Helper: call a resolve function, emit its error JSON if it fails.
# Usage: try_resolve VAR resolve_fn arg1 arg2 ...
# On success, sets VAR to the resolved value.
# On failure, prints the error JSON to stdout and exits the script.
try_resolve() {
  local _var_name="$1"
  shift
  local _output
  _output=$("$@" 2>&1) || {
    # The subshell's json_error output is in _output — emit it
    echo "$_output"
    exit 1
  }
  eval "$_var_name=\$_output"
}

# Resolve a workflow state name to its UUID for a given team
resolve_state_id() {
  local team_key="$1"
  local state_name="$2"

  local result
  result=$(graphql "{ workflowStates(filter: { team: { key: { eq: \\\"$team_key\\\" } } }) { nodes { id name } } }")

  # Case-insensitive match
  local state_id
  state_id=$(echo "$result" | jq -r --arg name "$state_name" \
    '.data.workflowStates.nodes[] | select(.name | ascii_downcase == ($name | ascii_downcase)) | .id' | head -1)

  if [[ -z "$state_id" ]]; then
    local available
    available=$(echo "$result" | jq -r '[.data.workflowStates.nodes[].name] | join(", ")')
    json_error "$TOOL_NAME update" "State '$state_name' not found for team $team_key" "NOT_FOUND" "Available states: $available"
  fi
  echo "$state_id"
}

# Resolve a label name to its UUID for a given team
resolve_label_id() {
  local team_key="$1"
  local label_name="$2"

  local result
  result=$(graphql "{ issueLabels(filter: { team: { key: { eq: \\\"$team_key\\\" } } }, first: 100) { nodes { id name } } }")

  local label_id
  label_id=$(echo "$result" | jq -r --arg name "$label_name" \
    '.data.issueLabels.nodes[] | select(.name | ascii_downcase == ($name | ascii_downcase)) | .id' | head -1)

  if [[ -z "$label_id" ]]; then
    local available
    available=$(echo "$result" | jq -r '[.data.issueLabels.nodes[].name] | join(", ")')
    json_error "$TOOL_NAME update" "Label '$label_name' not found for team $team_key" "NOT_FOUND" "Available labels: $available"
  fi
  echo "$label_id"
}

# Resolve a user name/email to UUID
resolve_user_id() {
  local name="$1"

  # "me" shortcut
  if [[ "$name" == "me" ]]; then
    get_my_id
    return
  fi

  local result
  result=$(graphql "{ users(filter: { displayName: { containsi: \\\"$name\\\" } }) { nodes { id name email } } }")

  local user_id
  user_id=$(echo "$result" | jq -r '.data.users.nodes[0].id // empty')

  if [[ -z "$user_id" ]]; then
    json_error "$TOOL_NAME update" "User '$name' not found" "NOT_FOUND" "Use display name or 'me'"
  fi
  echo "$user_id"
}

# Resolve a cycle (by number or "current") for a team
resolve_cycle_id() {
  local team_key="$1"
  local cycle_ref="$2"

  if [[ "$cycle_ref" == "current" ]]; then
    local result
    result=$(graphql "{ cycles(filter: { team: { key: { eq: \\\"$team_key\\\" } }, isActive: { eq: true } }, first: 1) { nodes { id number } } }")
    local cycle_id
    cycle_id=$(echo "$result" | jq -r '.data.cycles.nodes[0].id // empty')
    if [[ -z "$cycle_id" ]]; then
      json_error "$TOOL_NAME update" "No active cycle for team $team_key" "NOT_FOUND" "Run 'linear-cli cycles $team_key' to see available cycles"
    fi
    echo "$cycle_id"
  elif [[ "$cycle_ref" =~ ^[0-9]+$ ]]; then
    local result
    result=$(graphql "{ cycles(filter: { team: { key: { eq: \\\"$team_key\\\" } }, number: { eq: $cycle_ref } }, first: 1) { nodes { id number } } }")
    local cycle_id
    cycle_id=$(echo "$result" | jq -r '.data.cycles.nodes[0].id // empty')
    if [[ -z "$cycle_id" ]]; then
      json_error "$TOOL_NAME update" "Cycle $cycle_ref not found for team $team_key" "NOT_FOUND" "Run 'linear-cli cycles $team_key' to see available cycles"
    fi
    echo "$cycle_id"
  else
    json_error "$TOOL_NAME update" "Invalid cycle ref: $cycle_ref" "INVALID_ARG" "Use a cycle number or 'current'"
  fi
}

cmd_update() {
  local issue_id="$1"
  shift

  local state="" assignee="" priority="" label_add="" label_rm="" cycle=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --state|-s) state="$2"; shift 2 ;;
      --assignee|-a) assignee="$2"; shift 2 ;;
      --priority|-p) priority="$2"; shift 2 ;;
      --label) label_add="$2"; shift 2 ;;
      --remove-label) label_rm="$2"; shift 2 ;;
      --cycle) cycle="$2"; shift 2 ;;
      *) json_error "$TOOL_NAME update" "Unknown option: $1" "INVALID_ARG" \
           "Usage: linear-cli update <ID> [--state STATE] [--assignee NAME|me] [--priority 0-4] [--label NAME] [--remove-label NAME] [--cycle N|current]" ;;
    esac
  done

  local team_key="${issue_id%-*}"
  local issue_uuid
  try_resolve issue_uuid resolve_issue_uuid "$issue_id"

  # Build input object
  local input='{}'

  if [[ -n "$state" ]]; then
    local state_id
    try_resolve state_id resolve_state_id "$team_key" "$state"
    input=$(echo "$input" | jq --arg id "$state_id" '. + {stateId: $id}')
  fi

  if [[ -n "$assignee" ]]; then
    local user_id
    try_resolve user_id resolve_user_id "$assignee"
    input=$(echo "$input" | jq --arg id "$user_id" '. + {assigneeId: $id}')
  fi

  if [[ -n "$priority" ]]; then
    input=$(echo "$input" | jq --argjson pri "$priority" '. + {priority: $pri}')
  fi

  if [[ -n "$cycle" ]]; then
    local cycle_id
    try_resolve cycle_id resolve_cycle_id "$team_key" "$cycle"
    input=$(echo "$input" | jq --arg id "$cycle_id" '. + {cycleId: $id}')
  fi

  # Handle label mutations separately (add/remove use different mutations)
  if [[ -n "$label_add" ]]; then
    local label_id
    try_resolve label_id resolve_label_id "$team_key" "$label_add"
    graphql_mutation \
      'mutation AddLabel($issueId: String!, $labelId: String!) { issueAddLabel(id: $issueId, labelId: $labelId) { success } }' \
      "$(jq -n --arg iid "$issue_uuid" --arg lid "$label_id" '{issueId: $iid, labelId: $lid}')"
  fi

  if [[ -n "$label_rm" ]]; then
    local label_id
    try_resolve label_id resolve_label_id "$team_key" "$label_rm"
    graphql_mutation \
      'mutation RemoveLabel($issueId: String!, $labelId: String!) { issueRemoveLabel(id: $issueId, labelId: $labelId) { success } }' \
      "$(jq -n --arg iid "$issue_uuid" --arg lid "$label_id" '{issueId: $iid, labelId: $lid}')"
  fi

  # Apply main update if there are fields to change
  if [[ "$input" != '{}' ]]; then
    local result
    result=$(graphql_mutation \
      'mutation UpdateIssue($id: String!, $input: IssueUpdateInput!) { issueUpdate(id: $id, input: $input) { success issue { id identifier title state { name } priority assignee { name } labels { nodes { name } } } } }' \
      "$(jq -n --arg id "$issue_uuid" --argjson input "$input" '{id: $id, input: $input}')")

    local success
    success=$(echo "$result" | jq -r '.data.issueUpdate.success')
    if [[ "$success" != "true" ]]; then
      json_error "$TOOL_NAME update" "Failed to update issue" "API_ERROR" "Check the issue ID and field values"
    fi

    local issue_data
    issue_data=$(echo "$result" | jq '.data.issueUpdate.issue')

    local na
    na=$(next_actions \
        "$(next_action "linear-cli issue $issue_id" "View updated issue")")
    json_ok "$TOOL_NAME update" "$issue_data" "$na"
  else
    # Label-only update: re-fetch the issue to show current state
    cmd_issue "$issue_id"
  fi
}

cmd_labels() {
  local team_key="${1:-}"
  [[ -z "$team_key" ]] && json_error "$TOOL_NAME labels" "Team key required" "MISSING_ARG" \
    "Usage: linear-cli labels <team-key>"

  local result
  result=$(graphql "{ issueLabels(filter: { team: { key: { eq: \\\"$team_key\\\" } } }, first: 100) { nodes { id name color description } } }" \
    | jq '.data.issueLabels.nodes')

  local na
  na=$(next_actions \
      "$(next_action "linear-cli issues --mine" "List your assigned issues")" \
      "$(next_action "linear-cli update <ID> --label \"<name>\"" "Add a label to an issue")")
  json_ok "$TOOL_NAME labels" "$result" "$na"
}

cmd_states() {
  local team_key="${1:-}"
  [[ -z "$team_key" ]] && json_error "$TOOL_NAME states" "Team key required" "MISSING_ARG" \
    "Usage: linear-cli states <team-key>"

  local result
  result=$(graphql "{ workflowStates(filter: { team: { key: { eq: \\\"$team_key\\\" } } }) { nodes { id name type position } } }" \
    | jq '[.data.workflowStates.nodes | sort_by(.position) | .[] | {name, type}]')

  local na
  na=$(next_actions \
      "$(next_action "linear-cli update <ID> --state \"<name>\"" "Change an issue's state")")
  json_ok "$TOOL_NAME states" "$result" "$na"
}

cmd_cycles() {
  local team_key="${1:-}"
  [[ -z "$team_key" ]] && json_error "$TOOL_NAME cycles" "Team key required" "MISSING_ARG" \
    "Usage: linear-cli cycles <team-key>"

  local result
  result=$(graphql "{ cycles(filter: { team: { key: { eq: \\\"$team_key\\\" } } }, first: 10, orderBy: createdAt) { nodes { id number name startsAt endsAt progress { completed total } } } }" \
    | jq '.data.cycles.nodes')

  local na
  na=$(next_actions \
      "$(next_action "linear-cli update <ID> --cycle current" "Add an issue to the current cycle")")
  json_ok "$TOOL_NAME cycles" "$result" "$na"
}

cmd_comments() {
  local issue_id="${1:-}"
  [[ -z "$issue_id" ]] && json_error "$TOOL_NAME comments" "Issue ID required" "MISSING_ARG" \
    "Usage: linear-cli comments <ID>"

  local team_key="${issue_id%-*}"
  local number="${issue_id##*-}"

  if [[ ! "$number" =~ ^[0-9]+$ ]]; then
    json_error "$TOOL_NAME comments" "Invalid issue ID format. Expected: TEAM-123" "INVALID_ARG" "Use format TEAM-NUMBER"
  fi

  local result
  result=$(graphql "{ issues(filter: { number: { eq: $number }, team: { key: { eq: \\\"$team_key\\\" } } }, first: 1) { nodes { comments { nodes { id body createdAt user { name } } } } } }" \
    | jq '.data.issues.nodes[0].comments.nodes // []')

  local na
  na=$(next_actions \
      "$(next_action "linear-cli comment $issue_id \"<body>\"" "Add a comment")" \
      "$(next_action "linear-cli issue $issue_id" "View issue details")")
  json_ok "$TOOL_NAME comments" "$result" "$na"
}

cmd_search() {
  local query="$1"
  # Escape quotes in search query
  query=$(echo "$query" | sed 's/"/\\\\"/g')
  local raw
  raw=$(graphql "{ searchIssues(term: \\\"$query\\\", first: 20) { nodes { id identifier title state { name } assignee { name } priority } } }")
  local result
  result=$(echo "$raw" | jq '.data.searchIssues.nodes')

  local first_id
  first_id=$(echo "$result" | jq -r '.[0].identifier // empty')
  local na
  if [[ -n "$first_id" ]]; then
    na=$(next_actions \
        "$(next_action "linear-cli issue $first_id" "View details for top result")")
  else
    na=$(next_actions)
  fi
  json_ok "$TOOL_NAME search" "$result" "$na"
}

# Get current user's ID (cached for session)
get_my_id() {
  graphql "{ viewer { id } }" | jq -r '.data.viewer.id'
}

# Get team ID from team key
get_team_id() {
  local team_key="$1"
  local result
  result=$(graphql "{ teams(filter: { key: { eq: \\\"$team_key\\\" } }) { nodes { id } } }")
  local team_id
  team_id=$(echo "$result" | jq -r '.data.teams.nodes[0].id // empty')

  if [[ -z "$team_id" ]]; then
    json_error "$TOOL_NAME create" "Team '$team_key' not found" "NOT_FOUND" "Run 'linear-cli teams' to see available teams"
  fi
  echo "$team_id"
}

# Get "Todo" state ID for a team
get_todo_state_id() {
  local team_key="$1"
  local result
  result=$(graphql "{ workflowStates(filter: { team: { key: { eq: \\\"$team_key\\\" } }, name: { eq: \\\"Todo\\\" } }) { nodes { id } } }")
  echo "$result" | jq -r '.data.workflowStates.nodes[0].id // empty'
}

cmd_create() {
  local team_key="$1"
  local title="$2"
  shift 2

  local description=""
  local priority=""
  local parent=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --description|-d) description="$2"; shift 2 ;;
      --priority|-p) priority="$2"; shift 2 ;;
      --parent) parent="$2"; shift 2 ;;
      *) json_error "$TOOL_NAME create" "Unknown option: $1" "INVALID_ARG" "Usage: linear-cli create <team-key> \"<title>\" [--description \"...\"] [--priority 1-4] [--parent TEAM-123]" ;;
    esac
  done

  # Get team ID, user ID, and Todo state ID
  local team_id
  team_id=$(get_team_id "$team_key")
  local my_id
  my_id=$(get_my_id)
  local todo_state_id
  todo_state_id=$(get_todo_state_id "$team_key")

  # Build input as JSON using jq for proper escaping
  local input
  input=$(jq -n \
    --arg teamId "$team_id" \
    --arg title "$title" \
    --arg assigneeId "$my_id" \
    '{teamId: $teamId, title: $title, assigneeId: $assigneeId}')

  if [[ -n "$todo_state_id" ]]; then
    input=$(echo "$input" | jq --arg stateId "$todo_state_id" '. + {stateId: $stateId}')
  fi

  if [[ -n "$description" ]]; then
    input=$(echo "$input" | jq --arg desc "$description" '. + {description: $desc}')
  fi

  if [[ -n "$priority" ]]; then
    input=$(echo "$input" | jq --argjson pri "$priority" '. + {priority: $pri}')
  fi

  if [[ -n "$parent" ]]; then
    local parent_uuid
    parent_uuid=$(resolve_issue_uuid "$parent")
    input=$(echo "$input" | jq --arg pid "$parent_uuid" '. + {parentId: $pid}')
  fi

  local api_key
  api_key=$(get_api_key)

  local query='mutation IssueCreate($input: IssueCreateInput!) { issueCreate(input: $input) { success issue { id identifier title url state { name } assignee { name } } } }'
  local payload
  payload=$(jq -n --arg q "$query" --argjson vars "{\"input\": $input}" '{query: $q, variables: $vars}')

  local result
  result=$(curl -s -X POST \
    -H "Content-Type: application/json" \
    -H "Authorization: $api_key" \
    --data "$payload" \
    "$API_URL")

  if echo "$result" | jq -e '.errors' > /dev/null 2>&1; then
    local msg
    msg=$(echo "$result" | jq -r '.errors[0].message // "Unknown GraphQL error"')
    json_error "$TOOL_NAME create" "$msg" "API_ERROR" "Check your query syntax and API key"
  fi

  local success
  success=$(echo "$result" | jq -r '.data.issueCreate.success')

  if [[ "$success" != "true" ]]; then
    json_error "$TOOL_NAME create" "Failed to create issue" "API_ERROR" "Check the team key and title"
  fi

  local issue_data
  issue_data=$(echo "$result" | jq '.data.issueCreate.issue')
  local new_id
  new_id=$(echo "$issue_data" | jq -r '.identifier')

  local na
  na=$(next_actions \
      "$(next_action "linear-cli issue $new_id" "View the created issue")" \
      "$(next_action "linear-cli comment $new_id \"<comment>\"" "Add a comment to the new issue")")
  json_ok "$TOOL_NAME create" "$issue_data" "$na"
}

cmd_issues() {
  local mine=""
  local project=""
  local status=""
  local limit=20

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mine) mine="true"; shift ;;
      --project) project="$2"; shift 2 ;;
      --status) status="$2"; shift 2 ;;
      --limit) limit="$2"; shift 2 ;;
      *) json_error "$TOOL_NAME issues" "Unknown option: $1" "INVALID_ARG" "Usage: linear-cli issues [--mine] [--project NAME] [--status STATUS] [--limit N]" ;;
    esac
  done

  # Build filter
  local filter=""
  local filters=()

  if [[ -n "$mine" ]]; then
    filters+=("assignee: { isMe: { eq: true } }")
  fi

  if [[ -n "$status" ]]; then
    filters+=("state: { name: { eq: \\\"$status\\\" } }")
  fi

  if [[ -n "$project" ]]; then
    filters+=("project: { name: { eq: \\\"$project\\\" } }")
  fi

  if [[ ${#filters[@]} -gt 0 ]]; then
    filter="filter: { $(IFS=', '; echo "${filters[*]}") }, "
  fi

  local raw
  raw=$(graphql "{ issues(${filter}first: $limit, orderBy: updatedAt) { nodes { id identifier title state { name } priority assignee { name } project { name } updatedAt } } }")
  local issues
  issues=$(echo "$raw" | jq '.data.issues.nodes')

  # Truncate at 50
  local truncated
  truncated=$(json_truncate "$issues" 50)

  local first_id
  first_id=$(echo "$issues" | jq -r '.[0].identifier // empty')
  local na
  if [[ -n "$first_id" ]]; then
    na=$(next_actions \
        "$(next_action "linear-cli issue $first_id" "View details for first issue")" \
        "$(next_action "linear-cli search \"<query>\"" "Search for specific issues")")
  else
    na=$(next_actions \
        "$(next_action "linear-cli search \"<query>\"" "Search for issues")")
  fi
  json_ok "$TOOL_NAME issues" "$truncated" "$na"
}

# Main
if [[ $# -lt 1 ]]; then
    cmd_tree "$TOOL_NAME" "Linear issue management for AI agents" "$(jq -n '[
        {name: "issues",   description: "List issues with optional filters",     usage: "linear-cli issues [--mine] [--project NAME] [--status STATUS] [--limit N]"},
        {name: "issue",    description: "Get details for a specific issue",      usage: "linear-cli issue <ID>"},
        {name: "update",   description: "Update issue fields",                   usage: "linear-cli update <ID> [--state S] [--assignee NAME|me] [--priority 0-4] [--label NAME] [--remove-label NAME] [--cycle N|current]"},
        {name: "create",   description: "Create a new issue (auto-assigned)",    usage: "linear-cli create <team-key> \"<title>\" [--description \"...\"] [--priority 1-4] [--parent TEAM-123]"},
        {name: "comment",  description: "Add a comment to an issue",            usage: "linear-cli comment <ID> \"<body>\""},
        {name: "comments", description: "List comments on an issue",            usage: "linear-cli comments <ID>"},
        {name: "search",   description: "Search issues by text",                usage: "linear-cli search <query>"},
        {name: "cancel",   description: "Cancel an issue (shortcut for update --state Canceled)", usage: "linear-cli cancel <ID>"},
        {name: "states",   description: "List workflow states for a team",       usage: "linear-cli states <team-key>"},
        {name: "labels",   description: "List labels for a team",               usage: "linear-cli labels <team-key>"},
        {name: "cycles",   description: "List cycles for a team",               usage: "linear-cli cycles <team-key>"},
        {name: "projects", description: "List all projects",                     usage: "linear-cli projects"},
        {name: "teams",    description: "List all teams",                        usage: "linear-cli teams"},
        {name: "me",       description: "Show current user info",               usage: "linear-cli me"}
    ]')"
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
  me) cmd_me ;;
  teams) cmd_teams ;;
  projects) cmd_projects ;;
  issue)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME issue" "Issue ID required" "MISSING_ARG" "Usage: linear-cli issue <ID>"
    cmd_issue "$1"
    ;;
  update)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME update" "Issue ID required" "MISSING_ARG" \
      "Usage: linear-cli update <ID> [--state S] [--assignee NAME|me] [--priority 0-4] [--label NAME] [--cycle N|current]"
    cmd_update "$@"
    ;;
  comment)
    [[ $# -lt 2 ]] && json_error "$TOOL_NAME comment" "Issue ID and comment body required" "MISSING_ARG" "Usage: linear-cli comment <ID> \"<body>\""
    cmd_comment "$1" "$2"
    ;;
  comments)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME comments" "Issue ID required" "MISSING_ARG" "Usage: linear-cli comments <ID>"
    cmd_comments "$1"
    ;;
  search)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME search" "Search query required" "MISSING_ARG" "Usage: linear-cli search <query>"
    cmd_search "$*"
    ;;
  issues) cmd_issues "$@" ;;
  create)
    [[ $# -lt 2 ]] && json_error "$TOOL_NAME create" "Team key and title required" "MISSING_ARG" \
      "Usage: linear-cli create <team-key> \"<title>\" [--description \"...\"] [--priority 1-4] [--parent TEAM-123]"
    cmd_create "$@"
    ;;
  cancel)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME cancel" "Issue ID required" "MISSING_ARG" "Usage: linear-cli cancel <ID>"
    cmd_cancel "$1"
    ;;
  states)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME states" "Team key required" "MISSING_ARG" "Usage: linear-cli states <team-key>"
    cmd_states "$1"
    ;;
  labels)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME labels" "Team key required" "MISSING_ARG" "Usage: linear-cli labels <team-key>"
    cmd_labels "$1"
    ;;
  cycles)
    [[ $# -lt 1 ]] && json_error "$TOOL_NAME cycles" "Team key required" "MISSING_ARG" "Usage: linear-cli cycles <team-key>"
    cmd_cycles "$1"
    ;;
  help|--help|-h)
    cmd_tree "$TOOL_NAME" "Linear issue management for AI agents" "$(jq -n '[]')"
    ;;
  *)
    json_error "$TOOL_NAME" "Unknown command: $CMD" "INVALID_ARG" "Run 'linear-cli' with no args to see available commands"
    ;;
esac

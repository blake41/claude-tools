#!/bin/bash
set -eo pipefail

REAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$REAL_SCRIPT")"

source "$SCRIPT_DIR/cf-common.sh"
source "$SCRIPT_DIR/../cli-envelope.sh"

TOOL_NAME="cf-logs"

# Defaults
FORMAT="pretty"
SAMPLING_RATE=""
FILTER=""
ONCE=false

# Parse arguments
WORKER_NAME=""
EXTRA_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --format)
            FORMAT="$2"
            shift 2
            ;;
        --sampling)
            SAMPLING_RATE="$2"
            shift 2
            ;;
        --status)
            EXTRA_ARGS+=("--status" "$2")
            shift 2
            ;;
        --search)
            EXTRA_ARGS+=("--search" "$2")
            shift 2
            ;;
        --ip)
            EXTRA_ARGS+=("--ip" "$2")
            shift 2
            ;;
        --once)
            ONCE=true
            shift
            ;;
        --help|-h)
            cmd_tree "$TOOL_NAME" "Stream real-time logs from Cloudflare Workers" "$(jq -n '[
                {name: "tail", description: "Stream logs from a worker", usage: "cf-logs <worker-name> [--format pretty|json] [--sampling RATE] [--status CODE] [--search TEXT] [--once]"}
            ]')"
            exit 0
            ;;
        -*)
            json_error "$TOOL_NAME" "Unknown option: $1" "INVALID_ARG" "Run: cf-logs --help"
            ;;
        *)
            WORKER_NAME="$1"
            shift
            ;;
    esac
done

if [[ -z "$WORKER_NAME" ]]; then
    cmd_tree "$TOOL_NAME" "Stream real-time logs from Cloudflare Workers" "$(jq -n '[
        {name: "tail", description: "Stream logs from a worker", usage: "cf-logs <worker-name> [--format pretty|json] [--sampling RATE] [--status CODE] [--search TEXT] [--once]"}
    ]')"
    exit 0
fi

# Check if wrangler is available
if ! command -v wrangler &>/dev/null; then
    json_error "$TOOL_NAME" "wrangler not found" "MISSING_DEP" "Install with: npm install -g wrangler"
fi

# Build wrangler tail command
CMD=(wrangler tail "$WORKER_NAME" --format "$FORMAT")

if [[ -n "$SAMPLING_RATE" ]]; then
    CMD+=(--sampling-rate "$SAMPLING_RATE")
fi

CMD+=("${EXTRA_ARGS[@]}")

# JSON preamble before streaming starts
jq -n \
    --arg cmd "$TOOL_NAME" \
    --arg worker "$WORKER_NAME" \
    '{ok: true, streaming: true, command: $cmd, worker: $worker, note: "Streaming output follows. Press Ctrl+C to stop."}'

if [[ "$ONCE" == true ]]; then
    # Run briefly for testing (macOS compatible)
    "${CMD[@]}" &
    PID=$!
    sleep 10
    kill $PID 2>/dev/null || true
else
    "${CMD[@]}"
fi
